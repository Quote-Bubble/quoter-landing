---
const steps = [
  {
    n: "01",
    title: "We put Quoter on your website",
    body: "We add a simple quote box to your site — free. Takes a few minutes, and you don’t need to do anything technical.",
  },
  {
    n: "02",
    title: "Customer types an address",
    body: "They put in where they live. Quoter measures the roof from a satellite photo in a few seconds.",
  },
  {
    n: "03",
    title: "They see a price — you get the call",
    body: "They see what the job might cost and can ask you to come round. You don’t need to drive out first.",
  },
];
---

<section id="how" class="cv-auto relative mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-28">
  <div class="mx-auto max-w-2xl text-center" data-reveal>
    <span class="section-label">How it works</span>
    <h2 class="font-display mt-4 text-[clamp(1.85rem,6vw,3.1rem)] leading-[1.05] text-ink">
      Three simple steps.
    </h2>
    <p class="mx-auto mt-4 max-w-lg text-[16px] leading-relaxed text-ink-soft sm:text-[18px]">
      Try the box above — that is what your customers see on your site.
    </p>
  </div>

  <div class="how-track mt-12 sm:mt-20" data-how-track>
    {steps.map((s, i) => (
      <Fragment>
        <div class="how-step" data-reveal data-delay={String(i + 1)}>
          <span class="how-num" aria-hidden="true">{s.n}</span>
          <h3 class="font-display how-title">{s.title}</h3>
          <p class="how-body">{s.body}</p>
        </div>
        {i < steps.length - 1 && (
          <div class="how-line" aria-hidden="true" data-how-line>
            <svg class="how-line-svg" viewBox="0 0 80 24" preserveAspectRatio="none">
              <path
                class="how-line-path"
                d="M4 12 H76"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              />
            </svg>
            <svg class="how-line-svg how-line-svg--vert" viewBox="0 0 24 48" preserveAspectRatio="none">
              <path
                class="how-line-path"
                d="M12 4 V44"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              />
            </svg>
          </div>
        )}
      </Fragment>
    ))}
  </div>
</section>

<style>
  .how-track {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
  }
  @media (min-width: 1024px) {
    .how-track {
      flex-direction: row;
      align-items: flex-start;
      gap: 0;
    }
  }

  .how-step {
    position: relative;
    flex: 1;
    padding: 8px 12px 20px;
    text-align: center;
  }
  @media (min-width: 1024px) {
    .how-step {
      padding: 0 18px;
    }
  }

  .how-num {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.08em;
    color: var(--color-brand-500);
  }

  .how-title {
    margin: 0.7rem 0 0;
    font-size: clamp(1.25rem, 2.4vw, 1.5rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }

  .how-body {
    margin: 0.75rem auto 0;
    max-width: 18rem;
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }

  .how-line {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand-400);
    flex: none;
    padding: 4px 0 18px;
  }
  .how-line-svg {
    display: none;
    width: 56px;
    height: 24px;
    overflow: visible;
  }
  .how-line-svg--vert {
    display: block;
    width: 24px;
    height: 36px;
  }
  @media (min-width: 1024px) {
    .how-line {
      padding: 2.1rem 4px 0;
      align-self: flex-start;
    }
    .how-line-svg {
      display: block;
      width: 48px;
      height: 24px;
    }
    .how-line-svg--vert {
      display: none;
    }
  }

  .how-line-path {
    stroke-dasharray: 80;
    stroke-dashoffset: 80;
    transition: none;
  }
  .how-track.is-drawn .how-line:nth-child(2) .how-line-path {
    transition: stroke-dashoffset 0.7s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) 0.2s;
    stroke-dashoffset: 0;
  }
  .how-track.is-drawn .how-line:nth-child(4) .how-line-path {
    transition: stroke-dashoffset 0.7s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) 0.45s;
    stroke-dashoffset: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .how-line-path {
      stroke-dashoffset: 0 !important;
      transition: none !important;
    }
  }
</style>

<script>
  function initHowLines() {
    const track = document.querySelector<HTMLElement>("[data-how-track]");
    if (!track || track.dataset.bound === "1") return;
    track.dataset.bound = "1";

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) {
      track.classList.add("is-drawn");
      return;
    }

    const io = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) return;
        track.classList.add("is-drawn");
        io.disconnect();
      },
      { threshold: 0.35 }
    );
    io.observe(track);
  }

  initHowLines();
  document.addEventListener("astro:after-swap", () => {
    const track = document.querySelector<HTMLElement>("[data-how-track]");
    if (track) delete track.dataset.bound;
    initHowLines();
  });
</script>
