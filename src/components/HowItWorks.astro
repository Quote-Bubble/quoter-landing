---
const steps = [
  {
    n: "1",
    title: "Enter your address",
    body: "Type in the address of your home. That is all we need to get started. No forms and no phone number.",
    icon: `<path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="2"/>`,
  },
  {
    n: "2",
    title: "We measure your roof",
    body: "Quoter looks at satellite photos of your home and works out the size and shape of your roof in a few seconds.",
    icon: `<path d="M3 11 12 4l9 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M5 10v9h14v-9" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>`,
  },
  {
    n: "3",
    title: "See your price",
    body: "You see a price range for the work straight away. If you want to go ahead, a local roofer visits to confirm the exact price. That visit is free too.",
    icon: `<path d="M4 13 12 5l7 .5.5 7L11.5 20a2 2 0 0 1-2.8 0L4 15.8a2 2 0 0 1 0-2.8Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><circle cx="15" cy="9" r="1.4" fill="currentColor"/>`,
  },
];
---

<section id="how" class="cv-auto relative mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-28">
  <div class="mx-auto max-w-2xl text-center" data-reveal>
    <span class="section-label">How it works</span>
    <h2 class="font-display mt-4 text-[clamp(1.85rem,6vw,3.1rem)] leading-[1.05] text-ink">
      Your price in three steps.
    </h2>
    <p class="mx-auto mt-4 max-w-lg text-[16px] leading-relaxed text-ink-soft sm:text-[18px]">
      The whole thing takes about a minute, and you are not committing to anything.
    </p>
  </div>

  <div class="mt-10 flex flex-col gap-5 sm:mt-16 sm:gap-6 lg:flex-row lg:items-stretch lg:gap-3">
    {steps.map((s, i) => (
      <Fragment>
        <div class="how-card" data-reveal data-delay={String(i + 1)}>
          <div class="how-icon">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" set:html={s.icon} />
            <span class="how-badge">{s.n}</span>
          </div>
          <h3 class="font-display mt-6 text-[24px] leading-tight text-ink">{s.title}</h3>
          <p class="mx-auto mt-3 max-w-xs text-[16.5px] leading-relaxed text-ink-soft">{s.body}</p>
        </div>
        {i < steps.length - 1 && (
          <div class="how-arrow" aria-hidden="true" data-reveal data-delay={String(i + 1)}>
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none">
              <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        )}
      </Fragment>
    ))}
  </div>
</section>

<style>
  .how-card {
    position: relative;
    flex: 1;
    background: #fff;
    border-radius: 28px;
    padding: 28px 22px;
    text-align: center;
    box-shadow:
      0 1px 2px rgba(16, 24, 40, 0.04),
      0 24px 50px -30px rgba(23, 60, 160, 0.35);
    border: 1px solid var(--color-line);
  }
  @media (min-width: 640px) {
    .how-card {
      padding: 36px 28px;
    }
  }
  .how-icon {
    position: relative;
    margin: 0 auto;
    width: 68px;
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 20px;
    background: linear-gradient(160deg, var(--color-brand-50), #dfeaff);
    color: var(--color-brand-600);
  }
  .how-badge {
    position: absolute;
    top: -10px;
    right: -10px;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: linear-gradient(180deg, var(--color-brand-500), var(--color-brand-600));
    color: #fff;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    box-shadow: 0 6px 14px -4px rgba(31, 87, 240, 0.6);
    border: 2px solid #fff;
  }
  .how-arrow {
    display: none;
    flex: none;
    align-items: center;
    color: var(--color-brand-300);
  }
  @media (min-width: 1024px) {
    .how-arrow { display: flex; }
  }
</style>
