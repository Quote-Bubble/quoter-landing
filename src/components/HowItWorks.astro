---
const steps = [
  {
    n: "01",
    title: "We put Quoter on your site",
    body: "We put our quote box on your site. It takes a few minutes and requires nothing technical from you.",
  },
  {
    n: "02",
    title: "Customers request quotes",
    body: "They put in where they live and what job they want, mark out the relevant areas, and answer questions where necessary. We price the quote exactly like you would.",
  },
  {
    n: "03",
    title: "You receive the quote",
    body: "You receive their quote in our dashboard immediately, alongside all the others.",
  },
  {
    n: "04",
    title: "You pick the best leads",
    body: "You can pick out the quotes you want to manually verify, complete with estimated price, phone number, and postcode.",
  },
];
---

<section id="how" class="cv-auto relative mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-28">
  <div class="mx-auto max-w-4xl text-center" data-reveal>
    <h2 class="font-display how-heading text-ink">
      We'll do it all for you
      <span class="how-heading-line2">
        <span class="how-heading-accent">for free</span>.
      </span>
    </h2>
  </div>

  <div class="how-track mt-12 sm:mt-20" data-how-track>
    {steps.map((s, i) => (
      <Fragment>
        <div class="how-step" data-reveal data-delay={String(i + 1)}>
          <span class="how-num" aria-hidden="true">{s.n}</span>
          <h3 class="font-display how-title">{s.title}</h3>
          <p class="how-body">{s.body}</p>
        </div>
        {i < steps.length - 1 && (
          <div class="how-line" aria-hidden="true" data-how-line>
            <svg class="how-line-svg" viewBox="0 0 80 24" preserveAspectRatio="none">
              <path
                class="how-line-path"
                d="M4 12 H76"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              />
            </svg>
            <svg class="how-line-svg how-line-svg--vert" viewBox="0 0 24 48" preserveAspectRatio="none">
              <path
                class="how-line-path"
                d="M12 4 V44"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              />
            </svg>
          </div>
        )}
      </Fragment>
    ))}
  </div>
</section>

<style>
  .how-heading {
    margin: 0;
    font-size: clamp(1.55rem, 4vw, 2.5rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.03em;
  }
  .how-heading-line2 {
    display: block;
  }
  .how-heading-accent {
    position: relative;
    display: inline-block;
    color: var(--color-brand-500);
  }
  .how-heading-accent::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.08em;
    height: 0.07em;
    border-radius: 999px;
    background: var(--color-brand-500);
    transform-origin: left center;
    transform: scaleX(0);
    transition: transform 0.6s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) 0.35s;
  }
  [data-reveal].is-in .how-heading-accent::after {
    transform: scaleX(1);
  }
  @media (max-width: 640px) {
    .how-heading {
      font-size: clamp(1.4rem, 6.2vw, 1.9rem);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .how-heading-accent::after {
      transition: none;
      transform: scaleX(1);
    }
  }

  .how-track {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
  }
  @media (min-width: 1024px) {
    .how-track {
      flex-direction: row;
      align-items: flex-start;
      gap: 0;
    }
  }

  .how-step {
    position: relative;
    flex: 1;
    padding: 8px 12px 20px;
    text-align: center;
  }
  @media (min-width: 1024px) {
    .how-step {
      padding: 0 18px;
    }
  }

  .how-num {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.08em;
    color: var(--color-brand-500);
  }

  .how-title {
    margin: 0.7rem 0 0;
    font-size: clamp(1.25rem, 2.4vw, 1.5rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--color-ink);
  }

  .how-body {
    margin: 0.75rem auto 0;
    max-width: 18rem;
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }

  .how-line {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand-400);
    flex: none;
    padding: 4px 0 18px;
  }
  .how-line-svg {
    display: none;
    width: 56px;
    height: 24px;
    overflow: visible;
  }
  .how-line-svg--vert {
    display: block;
    width: 24px;
    height: 36px;
  }
  @media (min-width: 1024px) {
    .how-line {
      padding: 2.1rem 4px 0;
      align-self: flex-start;
    }
    .how-line-svg {
      display: block;
      width: 48px;
      height: 24px;
    }
    .how-line-svg--vert {
      display: none;
    }
  }

  .how-line-path {
    stroke-dasharray: 80;
    stroke-dashoffset: 80;
    transition: none;
  }
  .how-track.is-drawn .how-line:nth-child(2) .how-line-path {
    transition: stroke-dashoffset 0.7s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) 0.2s;
    stroke-dashoffset: 0;
  }
  .how-track.is-drawn .how-line:nth-child(4) .how-line-path {
    transition: stroke-dashoffset 0.7s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) 0.45s;
    stroke-dashoffset: 0;
  }
  .how-track.is-drawn .how-line:nth-child(6) .how-line-path {
    transition: stroke-dashoffset 0.7s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) 0.7s;
    stroke-dashoffset: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .how-line-path {
      stroke-dashoffset: 0 !important;
      transition: none !important;
    }
  }
</style>

<script>
  function initHowLines() {
    const track = document.querySelector<HTMLElement>("[data-how-track]");
    if (!track || track.dataset.bound === "1") return;
    track.dataset.bound = "1";

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) {
      track.classList.add("is-drawn");
      return;
    }

    const io = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) return;
        track.classList.add("is-drawn");
        io.disconnect();
      },
      { threshold: 0.35 }
    );
    io.observe(track);
  }

  initHowLines();
  document.addEventListener("astro:after-swap", () => {
    const track = document.querySelector<HTMLElement>("[data-how-track]");
    if (track) delete track.dataset.bound;
    initHowLines();
  });
</script>
