---
// The real, working Quoter widget — embedded via iframe from
// quoter-widget-frontend. Replaces the former in-page mock.
//
// The widget has exactly two on-screen sizes: a fixed collapsed search bar
// and a fixed expanded panel. The iframe is ALWAYS absolutely positioned over
// a reserved, constant-height slot, so no size change the widget makes ever
// moves anything on the host page. The panel simply overlays downward, like a
// dropdown. This is what killed the whole class of layout bugs (the Book-a-call
// gap, the hero jump, the morph recomputes) that the old dynamic-resize iframe
// caused.
//
//   embed -> host : { source:"quoter-embed", mode, height, stage }
//   host  -> embed: { source:"quoter-host", action:"focus" }
//
// mode is one of: collapsed | suggesting | expanded | overlay. `stage` is
// mirrored onto #quoter-widget so existing selectors keep working.
const EMBED_SRC =
  "https://quoter-widget-frontend.vercel.app/embed?roofer=quoter-landing-demo";

// Keep in sync with QUOTE_SIZES in the widget repo (lib/motion.ts).
const COLLAPSED_H = 90;
---

<div class="q" id="quoter-widget" data-stage="input" data-mode="collapsed">
  <iframe
    data-quoter-frame
    src={EMBED_SRC}
    title="Get an instant, free roof quote"
    loading="eager"
    scrolling="no"
    style={`height:${COLLAPSED_H}px`}
  ></iframe>
</div>

<style define:vars={{ collapsedH: `${COLLAPSED_H}px` }}>
  /* Reserved slot: a fixed height that never changes, so surrounding
     elements (Book a call, the scroll cue) never move. */
  .q {
    position: relative;
    width: 100%;
    height: var(--collapsedH);
  }
  /* The iframe is ALWAYS absolute over the slot, so growing it (suggestions,
     panel) overlays the page instead of pushing it. */
  .q iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--collapsedH);
    border: 0;
    background: transparent;
    /* Matches the widget's internal SHELL_TRANSITION (320ms, ease-soft) so
       the iframe and the card inside it grow/shrink in lockstep. */
    transition: height 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* Suggestions dropdown / expanded panel float above the content below. */
  .q[data-mode="suggesting"] iframe,
  .q[data-mode="expanded"] iframe {
    z-index: 60;
  }
  /* Mobile flow needs the whole screen. */
  .q[data-mode="overlay"] iframe {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100dvh;
    z-index: 9999;
    transition: none;
  }
</style>

<script>
  function initQuoterEmbed() {
    const holder = document.getElementById("quoter-widget");
    if (!holder || holder.dataset.embedBound === "1") return;
    holder.dataset.embedBound = "1";
    const frame = holder.querySelector(
      "[data-quoter-frame]",
    ) as HTMLIFrameElement | null;
    if (!frame) return;

    // Only trust messages that actually came from the widget's origin. The
    // `source: "quoter-embed"` marker below is just a field inside the payload
    // — any page or iframe can send that — so it identifies the protocol, it
    // does not authenticate the sender. Derived from the iframe's own src so
    // it stays correct if the embed moves.
    let embedOrigin: string | null = null;
    try {
      embedOrigin = new URL(frame.src, window.location.href).origin;
    } catch {
      return; // unparseable src — don't listen at all rather than listen to everyone
    }

    // Expanded panel height — keep in sync with the widget's QUOTE_SIZES and
    // the .q iframe transition on the host.
    const PANEL_H = 544;

    // The panel overlays downward and, on a short hero, its bottom lands over
    // the section below. Push the lower sections down just enough to leave a
    // clean gap beneath the panel. The gap is computed from the live layout
    // (scroll-invariant, since both rects shift together), so it adapts to
    // viewport height and where the bar sits.
    const lower = document.querySelector<HTMLElement>(".page-lower");
    const GAP_BELOW_PANEL = 64;
    function separateLowerSections() {
      if (!lower) return;
      // Measure against the panel's natural (unpadded) position.
      lower.style.paddingTop = "";
      const panelBottom = holder!.getBoundingClientRect().top + PANEL_H;
      const lowerTop = lower.getBoundingClientRect().top;
      const needed = Math.max(0, panelBottom + GAP_BELOW_PANEL - lowerTop);
      lower.style.paddingTop = `${Math.round(needed)}px`;
    }
    function resetLowerSections() {
      if (lower) lower.style.paddingTop = "";
    }

    // Scroll the page just enough that the expanded panel sits fully in view.
    // The panel overlays downward from the (in-flow) bar, so on a short hero
    // its bottom lands below the fold — nudge down to reveal it, without
    // pushing its top off the top of the screen.
    function scrollPanelIntoView() {
      const rect = holder!.getBoundingClientRect();
      const vh = window.innerHeight;
      const topMargin = 24;
      const bottomMargin = 24;
      const panelBottom = rect.top + PANEL_H;
      let delta = panelBottom - (vh - bottomMargin);
      if (delta <= 4) return;
      // Never scroll so far that the panel's own top goes above topMargin.
      const maxDelta = Math.max(0, rect.top - topMargin);
      delta = Math.min(delta, maxDelta);
      if (delta <= 4) return;
      const lenis = (window as unknown as {
        __lenis?: { scrollTo?: (t: number, o?: unknown) => void };
      }).__lenis;
      const target = window.scrollY + delta;
      if (lenis?.scrollTo) lenis.scrollTo(target, { duration: 0.55 });
      else window.scrollTo({ top: target, behavior: "smooth" });
    }

    window.addEventListener("message", (e: MessageEvent) => {
      if (e.origin !== embedOrigin) return;
      const d = e.data;
      if (!d || d.source !== "quoter-embed") return;

      const mode = typeof d.mode === "string" ? d.mode : "collapsed";
      const h = typeof d.height === "number" && d.height > 0 ? d.height : 0;
      const wasExpanded = holder.dataset.mode === "expanded";

      // Mirror stage + mode so host CSS/selectors keep working.
      if (typeof d.stage === "string") holder.dataset.stage = d.stage;
      holder.dataset.mode = mode;

      // Hide Book-a-call whenever the widget isn't a plain collapsed bar:
      //  - expanded / overlay (flow open): the panel covers that area anyway.
      //  - suggesting: the dropdown floats over it.
      // Both toggles map to the same global.css rules that hide the button
      // and its nav flying-clone.
      document.documentElement.classList.toggle(
        "quoter-flow-open",
        mode === "expanded" || mode === "overlay",
      );
      document.documentElement.classList.toggle(
        "quoter-suggesting",
        mode === "suggesting",
      );
      // Marks the expanded state for host CSS (panel elevation).
      document.documentElement.classList.toggle(
        "quoter-expanded",
        mode === "expanded",
      );

      // Drive the iframe height. Overlay (mobile) is fully CSS-driven, so
      // clear any inline height left over from a previous mode.
      if (mode === "overlay") {
        frame.style.height = "";
      } else if (h) {
        frame.style.height = `${h}px`;
      }

      if (mode === "expanded") {
        // Leave real space beneath the panel, then bring it fully into view.
        separateLowerSections();
        if (!wasExpanded) requestAnimationFrame(scrollPanelIntoView);
      } else {
        resetLowerSections();
      }
    });

    // Bridge for [data-try] buttons: focus the sealed input across the frame.
    (window as unknown as { __quoterFocus?: () => void }).__quoterFocus = () => {
      frame.contentWindow?.postMessage(
        { source: "quoter-host", action: "focus" },
        "*",
      );
    };
  }
  initQuoterEmbed();
  document.addEventListener("astro:after-swap", initQuoterEmbed);
</script>
