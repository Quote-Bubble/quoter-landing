---
// The main event: a wide, glass, search-bar-style interactive live-quote box.
// Swappable placeholder — the real embeddable widget mounts at #quoter-widget.
const presets = ["12 Oakfield Road, Leeds", "4 Elm Grove, Bristol", "27 Hillside Ave, Manchester"];
---

<div class="q" id="quoter-widget" data-stage="input">
  <!-- INPUT -->
  <div data-panel="input" class="q-panel">
    <div class="q-search">
      <svg class="q-search-icon" width="19" height="19" viewBox="0 0 24 24" fill="none">
        <path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z" stroke="#6b7280" stroke-width="2" stroke-linejoin="round"/>
        <circle cx="12" cy="10" r="2.5" stroke="#6b7280" stroke-width="2"/>
      </svg>
      <input type="text" data-input placeholder="Enter your address" autocomplete="off" spellcheck="false" aria-label="Your address" />
      <button type="button" data-go class="q-go">
        Get quote
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
    <div class="q-presets">
      <span class="q-presets-label">Try:</span>
      {presets.map((p) => <button type="button" class="q-chip" data-preset={p}>{p.split(",")[0]}</button>)}
    </div>
  </div>

  <!-- LOADING -->
  <div data-panel="loading" class="q-panel" hidden>
    <div class="q-map q-map--loading"><div class="q-spinner"></div></div>
    <div class="q-loading-text">Measuring roof from satellite…</div>
    <div class="q-loading-addr" data-loading-addr></div>
  </div>

  <!-- RESULT -->
  <div data-panel="result" class="q-panel" hidden>
    <div class="q-addressbar">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
        <path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z" stroke="#6b7280" stroke-width="2" stroke-linejoin="round"/>
        <circle cx="12" cy="10" r="2.5" stroke="#6b7280" stroke-width="2"/>
      </svg>
      <span data-result-addr>12 Oakfield Road, Leeds</span>
      <span class="q-check">✓</span>
    </div>

    <div class="q-grid">
      <div class="q-map">
        <svg viewBox="0 0 340 210" preserveAspectRatio="xMidYMid slice" class="q-map-svg">
          <defs>
            <linearGradient id="qsat" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#eaece7"/>
              <stop offset="1" stop-color="#d7dcd3"/>
            </linearGradient>
          </defs>
          <rect width="340" height="210" fill="url(#qsat)"/>
          <rect x="14" y="20" width="70" height="56" rx="3" fill="#cfd4cb"/>
          <rect x="266" y="24" width="62" height="54" rx="3" fill="#cfd4cb"/>
          <rect x="20" y="146" width="80" height="48" rx="3" fill="#cfd4cb"/>
          <rect x="256" y="140" width="78" height="58" rx="3" fill="#cfd4cb"/>
          <path d="M0 110 H340" stroke="#c5cbbf" stroke-width="14"/>
          <path d="M120 0 V210" stroke="#c5cbbf" stroke-width="13"/>
          <polygon class="q-roof-fill" points="140,60 220,60 238,106 122,106"/>
          <polygon class="q-roof-line" points="140,60 220,60 238,106 122,106"/>
          <circle class="q-pin" cx="122" cy="106" r="4"/>
          <circle class="q-pin" cx="238" cy="106" r="4"/>
          <circle class="q-pin" cx="220" cy="60" r="4"/>
          <circle class="q-pin" cx="140" cy="60" r="4"/>
        </svg>
        <div class="q-map-badge"><span data-area>92</span>&nbsp;m² measured</div>
      </div>

      <div class="q-details">
        <div>
          <div class="q-result-label">Ballpark estimate</div>
          <div class="q-result-price" data-price>£6,200&nbsp;–&nbsp;£8,400</div>
          <div class="q-result-meta" data-meta>≈ 92 m² · concrete tile · full strip &amp; re-roof</div>
        </div>
        <div class="q-actions">
          <button type="button" class="q-book">Book a free inspection</button>
          <button type="button" data-reset class="q-reset">Try another address</button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .q {
    width: 100%;
    text-align: left;
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(30px) saturate(1.8);
    -webkit-backdrop-filter: blur(30px) saturate(1.8);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 28px;
    padding: 18px;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.7) inset,
      0 2px 6px rgba(16, 24, 40, 0.05),
      0 40px 80px -32px rgba(23, 60, 160, 0.45);
  }

  .q-panel { animation: q-fade 0.35s cubic-bezier(0.16,1,0.3,1); }
  @keyframes q-fade { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

  /* search bar */
  .q-search {
    display: flex; align-items: center; gap: 10px;
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: 18px;
    padding: 8px 8px 8px 15px;
    box-shadow: 0 2px 8px rgba(16, 24, 40, 0.06), 0 1px 0 rgba(255,255,255,0.9) inset;
    transition: box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .q-search:focus-within {
    border-color: rgba(47,107,255,0.5);
    box-shadow: 0 0 0 4px rgba(47,107,255,0.14), 0 2px 8px rgba(16,24,40,0.06);
  }
  .q-search-icon { flex: none; }
  .q-search input {
    flex: 1; min-width: 0; border: none; outline: none; background: transparent;
    font-size: 16px; color: var(--color-ink); /* 16px avoids iOS zoom */
  }
  .q-go {
    flex: none;
    display: inline-flex; align-items: center; gap: 7px;
    background: linear-gradient(180deg, var(--color-brand-500), var(--color-brand-600));
    color: #fff; font-weight: 600; font-size: 14px;
    padding: 10px 16px; border-radius: 13px;
    box-shadow: 0 1px 0 rgba(255,255,255,0.25) inset, 0 8px 18px -6px rgba(31,87,240,0.55);
    cursor: pointer; transition: transform 0.16s ease, filter 0.16s ease;
  }
  .q-go:hover { transform: translateY(-1px); filter: brightness(1.05); }
  .q-go:active { transform: translateY(0); }

  .q-presets { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-top: 12px; padding: 0 4px; }
  .q-presets-label { font-size: 12.5px; color: var(--color-muted); }
  .q-chip {
    font-size: 12.5px; color: var(--color-ink-soft);
    background: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.85);
    border-radius: 999px; padding: 6px 13px;
    transition: all 0.15s ease; cursor: pointer;
  }
  .q-chip:hover { border-color: var(--color-brand-400); color: var(--color-brand-600); background: #fff; }

  @media (max-width: 520px) {
    .q {
      border-radius: 20px;
      padding: 12px;
      /* Glassier on mobile: more translucent so the blob frosts through */
      background: rgba(255, 255, 255, 0.38);
      backdrop-filter: blur(26px) saturate(1.9);
      -webkit-backdrop-filter: blur(26px) saturate(1.9);
      border-color: rgba(255, 255, 255, 0.55);
    }
    .q-search {
      background: rgba(255, 255, 255, 0.78);
      border-color: rgba(255, 255, 255, 0.85);
    }
    .q-search {
      display: grid;
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "icon input"
        "go go";
      align-items: center;
      gap: 10px 8px;
      padding: 12px;
      border-radius: 16px;
    }
    .q-search-icon { grid-area: icon; }
    .q-search input {
      grid-area: input;
      width: 100%;
      min-width: 0;
    }
    .q-go {
      grid-area: go;
      width: 100%;
      justify-content: center;
      padding: 12px 16px;
      border-radius: 12px;
    }
    /* Mobile: no preset chips — just the clean search bar */
    .q-presets { display: none; }
    .q-result-price { font-size: 26px; }
  }

  /* result */
  .q-addressbar {
    display: flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,0.8); border: 1px solid rgba(255,255,255,0.9);
    border-radius: 14px; padding: 11px 14px; margin-bottom: 14px;
    font-size: 14px; color: #313640;
  }
  .q-addressbar span:nth-of-type(1) { flex: 1; }
  .q-check { color: #12a150; font-weight: 700; }

  .q-grid { display: grid; grid-template-columns: 1fr; gap: 14px; }
  @media (min-width: 540px) {
    .q-grid { grid-template-columns: 1.05fr 1fr; }
  }

  .q-map {
    position: relative; border-radius: 16px; overflow: hidden;
    border: 1px solid rgba(255,255,255,0.6); min-height: 168px;
  }
  .q-map-svg { width: 100%; height: 100%; display: block; }
  .q-map-badge {
    position: absolute; left: 10px; bottom: 10px;
    background: rgba(10,11,13,0.72); color: #fff;
    font-size: 11px; font-weight: 600; padding: 4px 9px; border-radius: 8px;
  }
  .q-map--loading {
    display: flex; align-items: center; justify-content: center; min-height: 168px;
    background: linear-gradient(100deg, #eef0ec 30%, #f6f7f4 50%, #eef0ec 70%) 0 0 / 200% 100%, #eceee9;
    animation: q-shimmer 1.3s linear infinite; border-radius: 16px;
  }
  @keyframes q-shimmer { to { background-position: -200% 0, 0 0; } }
  .q-spinner {
    width: 32px; height: 32px; border-radius: 50%;
    border: 3px solid rgba(47,107,255,0.2); border-top-color: var(--color-brand-500);
    animation: q-spin 0.8s linear infinite;
  }
  @keyframes q-spin { to { transform: rotate(360deg); } }
  .q-loading-text { text-align: center; margin-top: 14px; font-size: 14px; font-weight: 500; color: var(--color-ink); }
  .q-loading-addr { text-align: center; margin-top: 3px; font-size: 12.5px; color: var(--color-muted); }

  .q-roof-fill { fill: rgba(47,107,255,0.24); opacity: 0; }
  .q-roof-line {
    fill: none; stroke: #2f6bff; stroke-width: 3; stroke-linejoin: round;
    stroke-dasharray: 400; stroke-dashoffset: 400;
    filter: drop-shadow(0 1px 3px rgba(47,107,255,0.4));
  }
  .q-pin { fill: #2f6bff; stroke: #fff; stroke-width: 1.75; opacity: 0; }
  [data-panel="result"].playing .q-roof-line { animation: q-draw 1.3s cubic-bezier(0.16,1,0.3,1) forwards 0.15s; }
  [data-panel="result"].playing .q-roof-fill { animation: q-rfill 0.9s ease forwards 1s; }
  [data-panel="result"].playing .q-pin { animation: q-pin 0.35s ease forwards 1.35s; }
  @keyframes q-draw { to { stroke-dashoffset: 0; } }
  @keyframes q-rfill { to { opacity: 1; } }
  @keyframes q-pin { to { opacity: 1; } }

  .q-details { display: flex; flex-direction: column; justify-content: space-between; gap: 14px; }
  .q-result-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.07em; color: var(--color-muted); font-weight: 600; }
  .q-result-price { font-family: var(--font-serif); font-size: 30px; font-weight: 600; letter-spacing: -0.01em; color: var(--color-ink); margin-top: 4px; }
  .q-result-meta { font-size: 12.5px; color: var(--color-muted); margin-top: 4px; }
  .q-actions { display: flex; flex-direction: column; gap: 6px; }
  .q-book {
    width: 100%;
    background: linear-gradient(180deg, var(--color-brand-500), var(--color-brand-600));
    color: #fff; font-weight: 600; font-size: 14px; padding: 12px; border-radius: 14px;
    box-shadow: 0 8px 18px -6px rgba(31,87,240,0.5); cursor: pointer;
    transition: transform 0.16s ease, filter 0.16s ease;
  }
  .q-book:hover { transform: translateY(-1px); filter: brightness(1.04); }
  .q-reset {
    width: 100%; padding: 8px; font-size: 13px; font-weight: 500; color: var(--color-muted);
    background: none; border: none; cursor: pointer; transition: color 0.15s ease;
  }
  .q-reset:hover { color: var(--color-ink); }

  @media (prefers-reduced-motion: reduce) {
    .q-spinner { animation-duration: 1.6s; }
    [data-panel="result"].playing .q-roof-line { animation: none; stroke-dashoffset: 0; }
    [data-panel="result"].playing .q-roof-fill,
    [data-panel="result"].playing .q-pin { animation: none; opacity: 1; }
    .q-map--loading { animation: none; }
  }
</style>

<script>
  function initQuoter() {
    const card = document.getElementById("quoter-widget");
    if (!card) return;

    const panels = {
      input: card.querySelector('[data-panel="input"]') as HTMLElement,
      loading: card.querySelector('[data-panel="loading"]') as HTMLElement,
      result: card.querySelector('[data-panel="result"]') as HTMLElement,
    };
    const input = card.querySelector("[data-input]") as HTMLInputElement;
    const goBtn = card.querySelector("[data-go]") as HTMLButtonElement;
    const resetBtn = card.querySelector("[data-reset]") as HTMLButtonElement;
    const loadingAddr = card.querySelector("[data-loading-addr]") as HTMLElement;
    const resultAddr = card.querySelector("[data-result-addr]") as HTMLElement;
    const areaEl = card.querySelector("[data-area]") as HTMLElement;
    const priceEl = card.querySelector("[data-price]") as HTMLElement;
    const metaEl = card.querySelector("[data-meta]") as HTMLElement;

    const materials = ["concrete tile", "clay tile", "natural slate", "interlocking tile"];

    function show(stage: "input" | "loading" | "result") {
      (Object.keys(panels) as Array<keyof typeof panels>).forEach((k) => {
        panels[k].hidden = k !== stage;
      });
      card.dataset.stage = stage;
    }
    function hash(str: string) {
      let h = 0;
      for (let i = 0; i < str.length; i++) h = (h * 31 + str.charCodeAt(i)) >>> 0;
      return h;
    }
    function fmt(n: number) {
      return "£" + (Math.round(n / 100) * 100).toLocaleString("en-GB");
    }
    function quote(a: string) {
      const h = hash(a.toLowerCase().trim());
      const area = 58 + (h % 82);
      return { area, material: materials[h % materials.length], low: area * 70, high: area * 95 };
    }

    // Scroll down just enough to reveal the box if it now overflows the viewport.
    function revealCard() {
      requestAnimationFrame(() => {
        const overflow = card.getBoundingClientRect().bottom - window.innerHeight;
        if (overflow > -16) {
          const lenis = (window as any).__lenis;
          const delta = overflow + 28;
          if (lenis) lenis.scrollTo(window.scrollY + delta);
          else window.scrollBy({ top: delta, behavior: "smooth" });
        }
      });
    }

    function run() {
      const address = input.value.trim();
      if (!address) { input.focus(); return; }
      loadingAddr.textContent = address;
      show("loading");
      revealCard();
      window.setTimeout(() => {
        const q = quote(address);
        resultAddr.textContent = address;
        areaEl.textContent = String(q.area);
        priceEl.innerHTML = fmt(q.low) + " – " + fmt(q.high);
        metaEl.textContent = `≈ ${q.area} m² · ${q.material} · full strip & re-roof`;
        show("result");
        panels.result.classList.remove("playing");
        void panels.result.offsetWidth;
        panels.result.classList.add("playing");
        revealCard();
      }, 1400);
    }

    goBtn.addEventListener("click", run);
    input.addEventListener("keydown", (e) => { if (e.key === "Enter") run(); });
    card.querySelectorAll("[data-preset]").forEach((chip) => {
      chip.addEventListener("click", () => {
        input.value = (chip as HTMLElement).dataset.preset || "";
        run();
      });
    });
    resetBtn.addEventListener("click", () => {
      input.value = "";
      show("input");
      input.focus();
    });
  }

  initQuoter();
  document.addEventListener("astro:after-swap", initQuoter);
</script>
