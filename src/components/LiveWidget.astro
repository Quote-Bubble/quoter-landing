---
// The real, working Quoter widget — embedded via iframe from
// quoter-widget-frontend. Replaces the former in-page mock.
//
// The iframe is a sealed cross-origin box (that isolation is exactly what
// makes it safe to embed on roofer sites), so it's bridged to the hero's
// dock-morph and focus logic with a small postMessage handshake:
//   embed -> host : { source:"quoter-embed", stage, height, overlay }
//   host  -> embed: { source:"quoter-host", action:"focus" }
// `stage` is mirrored onto this #quoter-widget element so every existing
// selector and the nav dock-morph keep working unchanged.
const EMBED_SRC =
  "https://quoter-widget-frontend.vercel.app/embed?roofer=quoter-landing-demo";
---

<div class="q" id="quoter-widget" data-stage="input">
  <iframe
    data-quoter-frame
    src={EMBED_SRC}
    title="Get an instant, free roof quote"
    loading="eager"
    scrolling="no"
  ></iframe>
</div>

<style>
  /* No card chrome here — the widget brings its own glass card inside the
     iframe. This element is just the morph target and sizing host. */
  .q {
    width: 100%;
  }
  .q iframe {
    display: block;
    width: 100%;
    height: 0; /* driven by the embed's postMessage */
    border: 0;
    background: transparent;
  }
  /* Mobile flow needs the whole screen; the embed asks for overlay and we
     pin the iframe to the viewport. */
  .q.is-overlay iframe {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100dvh;
    z-index: 9999;
  }
</style>

<script>
  function initQuoterEmbed() {
    const holder = document.getElementById("quoter-widget");
    if (!holder || holder.dataset.embedBound === "1") return;
    holder.dataset.embedBound = "1";
    const frame = holder.querySelector(
      "[data-quoter-frame]",
    ) as HTMLIFrameElement | null;
    if (!frame) return;

    window.addEventListener("message", (e: MessageEvent) => {
      const d = e.data;
      if (!d || d.source !== "quoter-embed") return;
      // Mirror stage so #quoter-widget[data-stage] selectors + the nav
      // dock-morph behave exactly as they did with the mock.
      if (typeof d.stage === "string") holder.dataset.stage = d.stage;
      if (d.overlay) {
        holder.classList.add("is-overlay");
      } else {
        holder.classList.remove("is-overlay");
        if (typeof d.height === "number" && d.height > 0) {
          frame.style.height = `${d.height}px`;
        }
      }
    });

    // Bridge for [data-try] buttons: focus the sealed input across the frame.
    (window as unknown as { __quoterFocus?: () => void }).__quoterFocus = () => {
      frame.contentWindow?.postMessage(
        { source: "quoter-host", action: "focus" },
        "*",
      );
    };
  }
  initQuoterEmbed();
  document.addEventListener("astro:after-swap", initQuoterEmbed);
</script>
