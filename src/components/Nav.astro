---
// Swap for your Calendly / Cal.com (or other) booking link
const meetingUrl = "https://cal.com/";
---

<!--
  One fixed wordmark for the whole journey. No handoff at the top — that was
  the "click". Spacer is layout-only; fly is always the visible Quoter once ready.
-->
<a href="/" class="brand-fly" data-brand-fly aria-label="Quoter home">Quoter</a>

<!--
  Flying meeting CTA: starts on the hero spacer, docks top-right as you scroll
  (same takeoff idea as the quote bubble / brand morph).
-->
<a
  href={meetingUrl}
  class="meeting-fly"
  data-meeting-fly
  target="_blank"
  rel="noopener noreferrer"
>
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <rect x="3" y="5" width="18" height="16" rx="2.5" stroke="currentColor" stroke-width="2"/>
    <path d="M3 10h18M8 3v4M16 3v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
  </svg>
  <span class="meeting-fly-label" data-meeting-label>Book a call</span>
</a>

<!-- Glass chrome for the docked brand. The quote widget is now a sealed
     iframe and no longer docks here; "Book a call" (meeting-fly) is the
     element that flies into the nav on scroll. -->
<div class="glass-nav" data-glass-nav inert style="--nav-merge: 0">
  <span class="glass-nav-brand-slot" data-nav-brand-slot aria-hidden="true">Quoter</span>
</div>

<style>
  .meeting-fly {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 68;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    margin: 0;
    padding: 0.8rem 1.05rem;
    border-radius: 28px;
    border: 0;
    background: linear-gradient(180deg, var(--color-brand-500), var(--color-brand-600));
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    color: #fff;
    text-decoration: none;
    white-space: nowrap;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.28) inset,
      0 10px 24px -8px rgba(31, 87, 240, 0.55);
    transform-origin: 0 0;
    will-change: transform, width, padding, font-size, border-radius;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    box-sizing: border-box;
  }
  .meeting-fly.is-ready {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .meeting-fly.is-docked {
    gap: 0.35rem;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.25) inset,
      0 8px 20px -8px rgba(31, 87, 240, 0.55);
  }
  .meeting-fly svg {
    flex: none;
  }
  .meeting-fly:hover {
    filter: brightness(1.05);
  }
  .meeting-fly:focus-visible {
    outline: 2px solid var(--color-brand-500);
    outline-offset: 3px;
  }

  .brand-fly {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 70;
    margin: 0;
    padding: 0;
    border: 0;
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 0.92;
    white-space: nowrap;
    text-decoration: none;
    transform-origin: 0 0;
    color: var(--color-ink);
    -webkit-text-fill-color: var(--color-ink);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: geometricPrecision;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .brand-fly.is-ready {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  /*
    Solid wordmark always. A highlight layer sweeps through the glyphs —
    the logo itself never slides away.
  */
  .brand-fly.is-hero::after {
    content: "Quoter";
    position: absolute;
    left: 0;
    top: 0;
    font: inherit;
    letter-spacing: inherit;
    line-height: inherit;
    white-space: nowrap;
    pointer-events: none;
    background-image: linear-gradient(
      105deg,
      transparent 0%,
      transparent 42%,
      rgba(91, 140, 255, 0.9) 50%,
      transparent 58%,
      transparent 100%
    );
    background-size: 220% 100%;
    background-repeat: no-repeat;
    background-position: 200% 50%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    animation: brand-sheen 9s linear infinite;
  }
  .brand-fly:not(.is-hero)::after {
    content: none;
    animation: none;
  }

  @keyframes brand-sheen {
    /* Pass through, then a long rest before the next sweep */
    0% {
      background-position: 200% 50%;
    }
    32% {
      background-position: -200% 50%;
    }
    100% {
      background-position: -200% 50%;
    }
  }

  .glass-nav {
    --nav-merge: 0;
    position: fixed;
    top: max(10px, env(safe-area-inset-top, 0px));
    left: 50%;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center; /* Quoter centred in the compact pill */
    gap: 0;
    /* Grows from brand-only → wide search dock (width set in JS too) */
    width: calc(104px + var(--nav-merge, 0) * (min(640px, 100vw - 24px) - 104px));
    max-width: min(640px, calc(100vw - 24px));
    padding: 6px 18px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(24px) saturate(1.7);
    -webkit-backdrop-filter: blur(24px) saturate(1.7);
    border: 1px solid rgba(255, 255, 255, 0.65);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.7) inset,
      0 2px 6px rgba(16, 24, 40, 0.05),
      0 18px 44px -18px rgba(23, 60, 160, 0.35);
    transform: translate(-50%, 0);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s var(--ease-out-soft, ease);
    box-sizing: border-box;
  }
  .glass-nav.is-shown {
    opacity: 1;
    pointer-events: auto;
  }
  /* Once search merges in: brand left, trail opens */
  .glass-nav.is-wide {
    justify-content: flex-start;
    gap: calc(4px + var(--nav-merge, 0) * 8px);
    padding: 6px 6px 6px 14px;
  }

  .glass-nav-brand-slot {
    flex: none;
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 0.92;
    color: transparent;
    user-select: none;
    pointer-events: none;
  }

  .glass-nav-divider {
    flex: none;
    width: 0;
    height: 18px;
    background: rgba(10, 11, 13, 0.1);
    opacity: 0;
    overflow: hidden;
  }
  .glass-nav.is-wide .glass-nav-divider {
    width: 1px;
    opacity: var(--nav-merge, 0);
    transform: scaleY(calc(0.4 + var(--nav-merge, 0) * 0.6));
  }

  /* Closed in compact pill so it can't shove Quoter off-centre */
  .widget-dock-slot {
    flex: 0 0 0;
    width: 0;
    min-width: 0;
    height: 40px;
    overflow: hidden;
    pointer-events: none;
    visibility: hidden;
  }
  .glass-nav.is-wide .widget-dock-slot {
    flex: 1 1 auto;
    width: auto;
  }

  @media (max-width: 639px) {
    .glass-nav {
      width: calc(96px + var(--nav-merge, 0) * (min(100vw - 16px, 640px) - 96px));
      max-width: min(100vw - 16px, 640px);
      padding-left: 16px;
      padding-right: 16px;
    }
    .glass-nav.is-wide {
      padding: 6px 6px 6px 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-fly.is-hero::after {
      content: none;
      animation: none;
    }
    .glass-nav {
      transition: opacity 0.2s ease;
    }
  }
</style>

<script>
  /**
   * Scroll triggers the dock flight; progress is time-based so stopping mid-scroll
   * never freezes a half-merged UI. Same morph math — it just plays through.
   */
  type DockFlight = {
    readonly t: number;
    on: (fn: () => void) => () => void;
    kick: () => void;
    destroy: () => void;
  };

  function ensureDockFlight(): DockFlight {
    const g = window as Window & { __dockFlight?: DockFlight | null };
    if (g.__dockFlight) return g.__dockFlight;

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    // Same pace both ways — undock felt too snappy
    const DURATION_DOCK = reduce ? 0 : 780;
    const DURATION_UNDOCK = reduce ? 0 : 780;
    const listeners = new Set<() => void>();
    let intent = 0;
    let t = 0;
    let animating = false;
    let animStart = 0;
    let animFrom = 0;
    let animTo = 0;
    let animDuration = DURATION_DOCK;
    let raf = 0;

    function getScroll() {
      const lenis = window.__lenis;
      if (lenis && typeof lenis.scroll === "number") return lenis.scroll;
      return window.scrollY || document.documentElement.scrollTop || 0;
    }

    function enterY() {
      // Fire further down the page
      return Math.min(240, Math.max(140, window.innerHeight * 0.24));
    }
    function exitY() {
      // Return once you’ve scrolled back above this band
      return Math.min(150, Math.max(80, window.innerHeight * 0.14));
    }

    function ease(u: number) {
      // Ease-out — moves immediately on trigger, soft land
      const x = Math.min(1, Math.max(0, u));
      return 1 - (1 - x) ** 3;
    }

    function notify() {
      listeners.forEach((fn) => fn());
    }

    function startAnim(to: number) {
      intent = to;
      animDuration = to === 1 ? DURATION_DOCK : DURATION_UNDOCK;
      if (animDuration <= 0 || Math.abs(t - to) < 0.001) {
        t = to;
        animating = false;
        notify();
        return;
      }
      animFrom = t;
      animTo = to;
      animStart = performance.now();
      animating = true;
      loop();
    }

    function syncIntent() {
      const y = getScroll();
      if (intent < 0.5 && y >= enterY()) startAnim(1);
      else if (intent >= 0.5 && y <= exitY()) startAnim(0);
    }

    function loop() {
      if (raf) return;
      const step = (now: number) => {
        raf = 0;
        syncIntent();
        if (animating) {
          const u = Math.min(1, (now - animStart) / animDuration);
          t = animFrom + (animTo - animFrom) * ease(u);
          if (u >= 1) {
            t = animTo;
            animating = false;
          }
        }
        notify();
        if (animating) raf = requestAnimationFrame(step);
      };
      raf = requestAnimationFrame(step);
    }

    const api: DockFlight = {
      get t() {
        return t;
      },
      on(fn) {
        listeners.add(fn);
        return () => listeners.delete(fn);
      },
      kick() {
        syncIntent();
        if (animating) loop();
        else notify();
      },
      destroy() {
        cancelAnimationFrame(raf);
        raf = 0;
        listeners.clear();
        g.__dockFlight = null;
      },
    };

    g.__dockFlight = api;
    return api;
  }

  document.addEventListener("astro:after-swap", () => {
    (window as Window & { __dockFlight?: DockFlight | null }).__dockFlight?.destroy();
  });

  function initBrandMorph() {
    const fly = document.querySelector<HTMLElement>("[data-brand-fly]");
    const spacer = document.querySelector<HTMLElement>("[data-brand-spacer]");
    const slot = document.querySelector<HTMLElement>("[data-nav-brand-slot]");
    const glass = document.querySelector<HTMLElement>("[data-glass-nav]");
    if (!fly || !spacer || !slot || !glass) return;

    const prev = (fly as any).__morphAbort as AbortController | undefined;
    prev?.abort();
    const ac = new AbortController();
    (fly as any).__morphAbort = ac;
    const { signal } = ac;
    const flight = ensureDockFlight();

    type Pt = { x: number; y: number; w: number; h: number; fs: number };
    let from: Pt | null = null;
    let ready = false;
    let running = true;

    function getScroll() {
      const lenis = window.__lenis;
      if (lenis && typeof lenis.scroll === "number") return lenis.scroll;
      return window.scrollY || document.documentElement.scrollTop || 0;
    }

    function measureFrom(): Pt {
      const r = spacer!.getBoundingClientRect();
      const y = getScroll();
      return {
        x: r.left,
        y: r.top + y,
        w: r.width,
        h: r.height,
        fs: parseFloat(getComputedStyle(spacer!).fontSize),
      };
    }

    function measureDock() {
      const r = slot!.getBoundingClientRect();
      return {
        x: r.left,
        y: r.top,
        w: r.width,
        h: r.height,
        fs: parseFloat(getComputedStyle(slot!).fontSize),
      };
    }

    function captureFrom() {
      from = measureFrom();
      fly!.style.fontSize = `${from.fs}px`;
    }

    function paint() {
      if (!running || !from || !ready) return;

      const y = getScroll();
      const dock = measureDock();
      const t = flight.t;

      const natX = from.x;
      const natY = from.y - y;
      const x = natX + (dock.x - natX) * t;
      const top = natY + (dock.y - natY) * t;
      const fs = from.fs + (dock.fs - from.fs) * t;
      fly!.style.fontSize = `${fs}px`;
      fly!.style.transform = `translate3d(${x}px, ${top}px, 0)`;
      fly!.classList.toggle("is-hero", t < 0.04);
      fly!.classList.toggle("is-docked", t > 0.97);

      const show = t > 0.42;
      glass!.classList.toggle("is-shown", show);
      if (show) glass!.removeAttribute("inert");
      else glass!.setAttribute("inert", "");
    }

    function kick() {
      if (getScroll() < 1) captureFrom();
      flight.kick();
    }

    function onResize() {
      captureFrom();
      kick();
    }

    function reveal() {
      if (signal.aborted) return;
      if (getScroll() > 0 && getScroll() < 48) {
        const lenis = window.__lenis;
        if (lenis?.scrollTo) lenis.scrollTo(0, { immediate: true });
        else window.scrollTo(0, 0);
      }
      captureFrom();
      paint();
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          if (signal.aborted) return;
          captureFrom();
          paint();
          fly!.classList.add("is-ready");
          if (getScroll() < 8) fly!.classList.add("is-hero");
          document.documentElement.classList.add("is-brand-morphing");
          ready = true;
          paint();
          flight.kick();
        });
      });
    }

    document.documentElement.classList.remove("is-brand-morphing");
    fly.classList.remove("is-ready", "is-active", "is-docked", "is-hero");

    const unsub = flight.on(() => {
      if (ready) paint();
    });

    function bindLenis() {
      const lenis = window.__lenis;
      if (!lenis?.on || (fly as any).__lenisBound) return;
      (fly as any).__lenisBound = true;
      lenis.on("scroll", kick);
    }
    bindLenis();
    const lenisTimer = window.setInterval(() => {
      bindLenis();
      if ((fly as any).__lenisBound) window.clearInterval(lenisTimer);
    }, 100);
    window.setTimeout(() => window.clearInterval(lenisTimer), 2000);

    window.addEventListener("scroll", kick, { passive: true, signal });
    window.addEventListener("resize", onResize, { passive: true, signal });
    fly.addEventListener(
      "click",
      (e) => {
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        if (location.pathname !== "/" && location.pathname !== "") return;
        e.preventDefault();
        const lenis = window.__lenis;
        if (lenis?.scrollTo) lenis.scrollTo(0, { duration: 1.15 });
        else window.scrollTo({ top: 0, behavior: "smooth" });
      },
      { signal }
    );

    let brandBooted = false;
    const bootBrand = () => {
      if (brandBooted || signal.aborted) return;
      brandBooted = true;
      reveal();
    };
    document.fonts?.ready?.then(() => window.setTimeout(bootBrand, 1450));
    window.setTimeout(bootBrand, 1600);

    signal.addEventListener("abort", () => {
      running = false;
      unsub();
      window.clearInterval(lenisTimer);
      (fly as any).__lenisBound = false;
      document.documentElement.classList.remove("is-brand-morphing");
    });
  }

  initBrandMorph();
  document.addEventListener("astro:after-swap", initBrandMorph);

  function initMeetingMorph() {
    const fly = document.querySelector<HTMLElement>("[data-meeting-fly]");
    const spacer = document.querySelector<HTMLElement>("[data-meeting-spacer]");
    const label = document.querySelector<HTMLElement>("[data-meeting-label]");
    const glass = document.querySelector<HTMLElement>("[data-glass-nav]");
    if (!fly || !spacer || !label || !glass) return;

    const prev = (fly as any).__morphAbort as AbortController | undefined;
    prev?.abort();
    const ac = new AbortController();
    (fly as any).__morphAbort = ac;
    const { signal } = ac;
    const flight = ensureDockFlight();

    type Box = { x: number; y: number; w: number; h: number };
    let from: Box | null = null;
    let ready = false;
    let running = true;

    function getScroll() {
      const lenis = window.__lenis;
      if (lenis && typeof lenis.scroll === "number") return lenis.scroll;
      return window.scrollY || document.documentElement.scrollTop || 0;
    }

    function measureFrom(): Box {
      const r = spacer!.getBoundingClientRect();
      return {
        x: r.left,
        y: r.top + getScroll(),
        w: r.width,
        h: r.height,
      };
    }

    function measureDock(): Box {
      const padR = window.innerWidth < 640 ? 12 : 16;
      const compact = window.innerWidth < 640;
      const w = compact ? 102 : 132;
      const h = compact ? 36 : 40;
      const glassR = glass!.getBoundingClientRect();
      const y = glass!.classList.contains("is-shown")
        ? glassR.top + (glassR.height - h) / 2
        : Math.max(10, glassR.top || 10);
      return {
        x: window.innerWidth - padR - w,
        y,
        w,
        h,
      };
    }

    function captureFrom() {
      from = measureFrom();
    }

    function paint() {
      if (!running || !ready) return;

      const y = getScroll();
      const dock = measureDock();
      const t = flight.t;

      // At rest, live-track the spacer (tab focus / bfcache / toolbar resize
      // otherwise leave Book a call sitting on a stale Y under the search bar).
      let natX: number;
      let natTop: number;
      let fromW: number;
      let fromH: number;
      if (t < 0.02) {
        const r = spacer!.getBoundingClientRect();
        natX = r.left;
        natTop = r.top;
        fromW = r.width;
        fromH = r.height;
        from = { x: r.left, y: r.top + y, w: r.width, h: r.height };
      } else {
        if (!from) return;
        natX = from.x;
        natTop = from.y - y;
        fromW = from.w;
        fromH = from.h;
      }

      const x = natX + (dock.x - natX) * t;
      const top = natTop + (dock.y - natTop) * t;
      const w = fromW + (dock.w - fromW) * t;
      const h = fromH + (dock.h - fromH) * t;
      const padY = 0.8 - (0.8 - 0.48) * t;
      const padX = 1.05 - (1.05 - 0.72) * t;
      const fs = 0.9 - (0.9 - 0.78) * t;
      const gap = 0.4 - (0.4 - 0.3) * t;
      const icon = 14 - (14 - 13) * t;
      const radius = 28 + (999 - 28) * t;

      fly!.style.width = `${Math.max(0, w)}px`;
      fly!.style.height = `${Math.max(0, h)}px`;
      fly!.style.padding = `${padY}rem ${padX}rem`;
      fly!.style.fontSize = `${fs}rem`;
      fly!.style.gap = `${gap}rem`;
      fly!.style.borderRadius = `${radius}px`;
      fly!.style.transform = `translate3d(${x}px, ${top}px, 0)`;
      const svg = fly!.querySelector("svg");
      if (svg) {
        svg.setAttribute("width", String(Math.round(icon)));
        svg.setAttribute("height", String(Math.round(icon)));
      }

      fly!.classList.toggle("is-docked", t > 0.92);
      label!.textContent = "Book a call";
    }

    function kick() {
      if (ready && flight.t < 0.05) captureFrom();
      flight.kick();
    }

    function resync() {
      if (!ready || signal.aborted) return;
      captureFrom();
      requestAnimationFrame(() => {
        captureFrom();
        paint();
        flight.kick();
      });
    }

    function boot() {
      if (signal.aborted || ready) return;
      document.documentElement.classList.remove("is-meeting-morphing");
      captureFrom();
      const natTop = from!.y - getScroll();
      fly!.style.width = `${from!.w}px`;
      fly!.style.height = `${from!.h}px`;
      fly!.style.transform = `translate3d(${from!.x}px, ${natTop}px, 0)`;
      fly!.classList.add("is-ready");
      document.documentElement.classList.add("is-meeting-morphing");
      ready = true;
      paint();
      requestAnimationFrame(() => {
        captureFrom();
        paint();
        flight.kick();
      });
    }

    const unsub = flight.on(() => {
      if (ready) paint();
    });

    function bindLenis() {
      const lenis = window.__lenis;
      if (!lenis?.on || (fly as any).__lenisBound) return;
      (fly as any).__lenisBound = true;
      lenis.on("scroll", kick);
    }
    bindLenis();
    const lenisTimer = window.setInterval(() => {
      bindLenis();
      if ((fly as any).__lenisBound) window.clearInterval(lenisTimer);
    }, 100);
    window.setTimeout(() => window.clearInterval(lenisTimer), 2000);

    window.addEventListener("scroll", kick, { passive: true, signal });
    window.addEventListener("resize", () => {
      if (ready) captureFrom();
      kick();
    }, { passive: true, signal });
    document.addEventListener(
      "visibilitychange",
      () => {
        if (document.visibilityState === "visible") resync();
      },
      { signal }
    );
    window.addEventListener("pageshow", resync, { signal });
    window.addEventListener("focus", resync, { signal });

    let booted = false;
    const scheduleBoot = () => {
      if (booted || signal.aborted) return;
      booted = true;
      requestAnimationFrame(() => requestAnimationFrame(boot));
    };
    document.fonts?.ready?.then(() => window.setTimeout(scheduleBoot, 2700));
    window.setTimeout(scheduleBoot, 2850);

    signal.addEventListener("abort", () => {
      running = false;
      unsub();
      window.clearInterval(lenisTimer);
      (fly as any).__lenisBound = false;
      document.documentElement.classList.remove("is-meeting-morphing");
      fly!.classList.remove("is-ready", "is-docked");
      fly!.style.cssText = "";
    });
  }

  initMeetingMorph();
  document.addEventListener("astro:after-swap", initMeetingMorph);

  function initWidgetMorph() {
    const widget = document.getElementById("quoter-widget") as HTMLElement | null;
    const spacer = document.querySelector<HTMLElement>("[data-widget-spacer]");
    const slot = document.querySelector<HTMLElement>("[data-widget-dock-slot]");
    const glass = document.querySelector<HTMLElement>("[data-glass-nav]");
    const brandSlot = document.querySelector<HTMLElement>("[data-nav-brand-slot]");
    if (!widget || !spacer || !slot || !glass || !brandSlot) return;

    const prev = (widget as any).__morphAbort as AbortController | undefined;
    prev?.abort();
    const ac = new AbortController();
    (widget as any).__morphAbort = ac;
    const { signal } = ac;
    const flight = ensureDockFlight();

    const smoother = (t: number) => {
      const u = Math.min(1, Math.max(0, t));
      return u * u * u * (u * (u * 6 - 15) + 10);
    };
    // Collapse lags travel slightly so size settles after the rise
    const easeCollapse = (t: number) => smoother((t - 0.04) / 0.96);

    type Box = { x: number; y: number; w: number; h: number };
    let from: Box | null = null;
    let ready = false;
    let running = true;
    // In-flow hero slot height — locked to the input footprint so loading/result
    // can grow the fixed card without reflowing brand / promise / support.
    let footprintH = 0;

    function getScroll() {
      const lenis = window.__lenis;
      if (lenis && typeof lenis.scroll === "number") return lenis.scroll;
      return window.scrollY || document.documentElement.scrollTop || 0;
    }

    function targetNavWidth() {
      return Math.min(640, window.innerWidth - (window.innerWidth < 640 ? 16 : 24));
    }

    function measureDockPill(): Box {
      const glassR = glass!.getBoundingClientRect();
      const brandR = brandSlot!.getBoundingClientRect();
      const slotR = slot!.getBoundingClientRect();
      const padR = 6;
      const gap = 10;
      const h = 40;
      const y = glassR.top + (glassR.height - h) / 2;
      // Prefer live slot once the nav has opened enough; else aim at final trail
      if (slotR.width > 80) {
        return { x: slotR.left, y: slotR.top, w: slotR.width, h: Math.max(slotR.height, h) };
      }
      const wide = targetNavWidth();
      const navLeft = (window.innerWidth - wide) / 2;
      const x = brandR.right + gap;
      const w = Math.max(180, navLeft + wide - padR - x);
      return { x, y, w, h };
    }

    function captureFromInFlow() {
      const shellEl = spacer!.parentElement as HTMLElement;
      const shellBox = shellEl.getBoundingClientRect();
      const h = widget!.offsetHeight;
      footprintH = h;
      spacer!.style.height = `${h}px`;
      from = {
        x: shellBox.left,
        y: shellBox.top + getScroll(),
        w: shellBox.width,
        h,
      };
    }

    function captureFromPinned() {
      const r = spacer!.getBoundingClientRect();
      const h = footprintH || parseFloat(spacer!.style.height) || from?.h || widget!.offsetHeight;
      spacer!.style.height = `${h}px`;
      from = {
        x: r.left,
        y: r.top + getScroll(),
        w: r.width,
        h,
      };
    }

    function paint() {
      if (!running || !from || !ready) return;

      const y = getScroll();
      const stage = widget!.dataset.stage || "input";
      const isInput = stage === "input";
      // Flight progress is timed after scroll trigger — same morph curves as before
      const raw = isInput ? flight.t : 0;
      const move = raw;
      const collapse = isInput ? easeCollapse(raw) : 0;

      const wide = targetNavWidth();
      const compact = window.innerWidth < 640 ? 96 : 104;
      glass!.style.setProperty("--nav-merge", collapse.toFixed(4));
      glass!.style.width = `${compact + (wide - compact) * collapse}px`;
      glass!.classList.toggle("is-wide", collapse > 0.02 && isInput);

      const dock = measureDockPill();
      const natTop = from.y - y;
      const toW = dock.w;
      const toH = dock.h;
      const toX = dock.x;
      const toY = dock.y;

      const x = from.x + (toX - from.x) * move;
      const top = natTop + (toY - natTop) * move;
      const w = from.w + (toW - from.w) * collapse;
      const h = from.h + (toH - from.h) * collapse;
      const radius = 28 + (999 - 28) * collapse;

      widget!.style.width = `${Math.max(0, w)}px`;
      if (widget!.dataset.scrollClose !== "1") {
        widget!.style.height = isInput ? `${Math.max(0, h)}px` : "auto";
      }
      widget!.style.maxWidth = "none";
      widget!.style.overflow = isInput && collapse > 0.55 ? "hidden" : "visible";
      widget!.style.borderRadius = isInput ? `${Math.max(0, radius)}px` : "";
      widget!.style.transform = `translate3d(${x}px, ${top}px, 0)`;
      widget!.style.setProperty("--q-m", collapse.toFixed(4));
      widget!.style.setProperty("--q-preset-pe", collapse > 0.35 ? "none" : "auto");
      widget!.dataset.docked = collapse > 0.94 && isInput ? "1" : "0";
      widget!.classList.toggle("is-morphing", move > 0.008);
      widget!.classList.toggle("is-collapsing", collapse > 0.62 && isInput);
    }

    function kick() {
      if (getScroll() < 2 && ready) captureFromPinned();
      flight.kick();
    }

    const shell = spacer!.parentElement as HTMLElement | null;
    const home = widget!.parentElement;

    function boot() {
      if (signal.aborted || ready) return;
      // 1) Measure in-flow (still inside the hero shell)
      document.documentElement.classList.remove("is-widget-morph-ready");
      widget!.style.cssText = "";
      if (home && shell && widget!.parentElement !== shell) {
        shell.appendChild(widget!);
      }
      // Freeze rise animation so morph measures the settled box
      shell?.classList.add("is-settled");
      captureFromInFlow();
      // 2) Pin transform to the current on-screen rect BEFORE fixed kicks in —
      // otherwise one paint lands the widget at top-left (flash/stutter).
      const natTop = from!.y - getScroll();
      widget!.style.width = `${from!.w}px`;
      widget!.style.maxWidth = "none";
      widget!.style.transform = `translate3d(${from!.x}px, ${natTop}px, 0)`;
      widget!.style.setProperty("--q-m", "0");
      // 3) Portal to <body> so we escape the hero stacking context
      document.body.appendChild(widget!);
      document.documentElement.classList.add("is-widget-morph-ready");
      ready = true;
      paint();
      requestAnimationFrame(() => {
        captureFromPinned();
        paint();
        flight.kick();
      });
    }

    const unsub = flight.on(() => {
      if (ready) paint();
    });

    // Stage change (e.g. scroll-dismiss back to input) — repaint dock morph
    const mo = new MutationObserver(() => {
      window.setTimeout(() => kick(), 40);
    });
    mo.observe(widget, { attributes: true, attributeFilter: ["data-stage"] });

    function bindLenis() {
      const lenis = window.__lenis;
      if (!lenis?.on || (widget as any).__dockLenis) return;
      (widget as any).__dockLenis = true;
      lenis.on("scroll", kick);
    }
    bindLenis();
    const lenisTimer = window.setInterval(() => {
      bindLenis();
      if ((widget as any).__dockLenis) window.clearInterval(lenisTimer);
    }, 100);
    window.setTimeout(() => window.clearInterval(lenisTimer), 2000);

    window.addEventListener("scroll", kick, { passive: true, signal });
    window.addEventListener("resize", () => {
      if (ready) captureFromPinned();
      kick();
    }, { passive: true, signal });

    let booted = false;
    const scheduleBoot = () => {
      if (booted || signal.aborted) return;
      booted = true;
      requestAnimationFrame(() => requestAnimationFrame(boot));
    };
    document.fonts?.ready?.then(() => window.setTimeout(scheduleBoot, 2550));
    window.setTimeout(scheduleBoot, 2700);

    signal.addEventListener("abort", () => {
      running = false;
      unsub();
      mo.disconnect();
      window.clearInterval(lenisTimer);
      (widget as any).__dockLenis = false;
      document.documentElement.classList.remove("is-widget-morph-ready");
      widget!.style.cssText = "";
      widget!.removeAttribute("data-docked");
      widget!.classList.remove("is-morphing", "is-collapsing");
      glass!.style.setProperty("--nav-merge", "0");
      glass!.style.width = "";
      glass!.classList.remove("is-wide");
      if (shell && widget!.parentElement !== shell) {
        shell.appendChild(widget!);
      }
    });
  }

  // Widget dock morph disabled: the quote widget is now a sealed cross-origin
  // iframe, so it can't collapse its internals into the nav pill the way the
  // mock did. It stays put in the hero; "Book a call" flies into the nav.
  // (initWidgetMorph retained above for reference / possible future re-enable.)
  void initWidgetMorph;
</script>
