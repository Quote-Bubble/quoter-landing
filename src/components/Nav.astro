---
import Logo from "./Logo.astro";
---

<header class="absolute inset-x-0 top-0 z-50 nav-load">
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-4 sm:px-6 sm:py-5">
    <a href="/" class="flex min-w-0 items-center gap-2 sm:gap-2.5" aria-label="Quoter home">
      <Logo size={28} />
      <span class="truncate text-[17px] font-semibold tracking-tight text-ink sm:text-[19px]">Quoter</span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      <a href="#how" class="text-sm font-medium text-ink-soft transition-colors hover:text-ink">How it works</a>
    </div>

    <button
      type="button"
      data-try
      class="btn-primary inline-flex shrink-0 items-center gap-1.5 rounded-full px-3.5 py-2 text-[13px] font-semibold sm:px-4 sm:text-sm"
    >
      Get my quote
    </button>
  </nav>
</header>
