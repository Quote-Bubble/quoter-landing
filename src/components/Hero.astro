---
import LiveWidget from "./LiveWidget.astro";

// Headline split to the LETTER so each character can resolve individually,
// with one continuous index driving the wave across both lines.
const lines = ["Instant Roof Quotes,", "Not Site Visits."];
let li = 0;
const heroLines = lines.map((line) =>
  line.split(" ").map((word) => word.split("").map((ch) => ({ ch, i: li++ })))
);
---

<!--
  One-viewport hero: the whole cluster (headline → search) stays composed
  in the first screen on desktop and mobile.
-->
<section class="hero relative flex min-h-[100svh] flex-col">
  <!-- Sonar pulse: rings burst from the blob's heart and birth the page -->
  <div class="pulse-rings" aria-hidden="true"><i></i><i></i></div>

  <div
    class="hero-stage relative z-10 mx-auto flex w-full max-w-6xl flex-1 flex-col items-center px-5 text-center sm:px-6"
  >
    <div class="hero-cluster w-full">
      <h1 class="font-display hero-title mx-auto max-w-4xl text-ink">
        {heroLines.map((words) => (
          <span class="hero-line">
            {words.map((letters, wi) => (
              <Fragment>
                <span class="hword">
                  {letters.map((l) => (
                    <span class="hl" style={`--li:${l.i}`}>{l.ch}</span>
                  ))}
                </span>
                {wi < words.length - 1 ? " " : ""}
              </Fragment>
            ))}
          </span>
        ))}
      </h1>

      <p class="sub-load hero-sub mx-auto max-w-xl leading-relaxed text-ink-soft">
        Get a free ballpark price for your roof in seconds, measured from
        satellite with no ladders and no pushy sales visit. Book a trusted local
        roofer only when you're ready.
      </p>

      <div class="cta-load hero-ctas flex flex-col items-center justify-center gap-3 sm:flex-row">
        <button
          type="button"
          data-try
          class="btn-primary inline-flex w-full items-center justify-center gap-2 rounded-full px-6 py-3 text-[15px] font-semibold sm:w-auto"
        >
          Try a live quote
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <a
          href="#how"
          class="btn-ghost inline-flex w-full items-center justify-center gap-2 rounded-full px-6 py-3 text-[15px] font-semibold sm:w-auto"
        >
          How it works
        </a>
      </div>

      <div class="hero-widget relative mx-auto w-full max-w-[620px]">
        <!-- The widget is traced into existence, the way it traces roofs -->
        <svg class="widget-trace" aria-hidden="true">
          <rect pathLength="100"></rect>
        </svg>
        <div class="widget-load">
          <LiveWidget />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* —— Sonar pulse rings: burst from the blob core, birthing the page —— */
  .pulse-rings {
    position: absolute;
    left: 50%;
    top: 64%;
    z-index: 0;
    pointer-events: none;
  }
  .pulse-rings i {
    position: absolute;
    left: -120px;
    top: -120px;
    width: 240px;
    height: 240px;
    border: 2px solid rgba(47, 107, 255, 0.55);
    border-radius: 50%;
    opacity: 0;
    transform: scale(0.12);
    animation: ring-pulse 1.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .pulse-rings i:nth-child(1) {
    animation-delay: 0.4s;
  }
  .pulse-rings i:nth-child(2) {
    animation-delay: 0.72s;
    border-width: 1.5px;
  }
  @keyframes ring-pulse {
    0% {
      opacity: 0;
      transform: scale(0.12);
    }
    12% {
      opacity: 0.6;
    }
    100% {
      opacity: 0;
      transform: scale(7);
    }
  }

  /* —— Widget trace: a glowing measurement line draws the widget's
        outline, then the glass materializes inside it —— */
  .widget-trace {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    animation: trace-life 1.55s linear 1s forwards;
  }
  .widget-trace rect {
    x: 1.5px;
    y: 1.5px;
    width: calc(100% - 3px);
    height: calc(100% - 3px);
    rx: 27px;
    fill: none;
    stroke: #2f6bff;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    filter: drop-shadow(0 0 9px rgba(47, 107, 255, 0.85));
    animation: trace-draw 0.9s var(--ease-out-expo) 1.05s forwards;
  }
  @media (max-width: 520px) {
    .widget-trace rect {
      rx: 21px;
    }
  }
  @keyframes trace-life {
    0% { opacity: 0; }
    6% { opacity: 1; }
    72% { opacity: 1; }
    100% { opacity: 0; }
  }
  @keyframes trace-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse-rings,
    .widget-trace {
      display: none;
    }
  }

  .hero-stage {
    justify-content: center;
    padding-top: max(5.75rem, calc(env(safe-area-inset-top, 0px) + 4.5rem));
    padding-bottom: clamp(1.25rem, 3.5svh, 2.75rem);
  }

  .hero-title {
    font-size: clamp(2.35rem, 5.8vw, 4.7rem);
    line-height: 1.03;
  }

  .hero-sub {
    margin-top: clamp(1rem, 2.2svh, 1.5rem);
    font-size: clamp(15px, 1.35vw, 17px);
  }

  .hero-ctas {
    margin-top: clamp(1.35rem, 2.8svh, 2.25rem);
  }

  .hero-widget {
    margin-top: clamp(1.5rem, 3.8svh, 2.75rem);
  }

  /* Mobile: pack from the top so the search stays on-screen with the blob */
  @media (max-width: 640px) {
    .hero-stage {
      justify-content: flex-start;
      padding-top: calc(env(safe-area-inset-top, 0px) + 4.75rem);
      padding-bottom: 1.25rem;
    }
    .hero-title {
      font-size: clamp(2rem, 9.5vw, 2.55rem);
    }
    .hero-sub {
      margin-top: 0.85rem;
      font-size: 15px;
      max-width: 22rem;
    }
    .hero-ctas {
      margin-top: 1.15rem;
      width: 100%;
      max-width: 22rem;
    }
    .hero-widget {
      margin-top: 2.5rem;
    }
  }

  /* Short phones / landscape: even tighter */
  @media (max-width: 640px) and (max-height: 720px) {
    .hero-title {
      font-size: clamp(1.85rem, 8vw, 2.2rem);
    }
    .hero-sub {
      margin-top: 0.65rem;
      font-size: 14px;
    }
    .hero-ctas {
      margin-top: 0.85rem;
      gap: 0.55rem;
    }
    .hero-widget {
      margin-top: 1.9rem;
    }
  }

  @media (min-width: 641px) and (max-height: 740px) {
    .hero-stage {
      justify-content: flex-start;
      padding-top: 5.25rem;
      padding-bottom: 1rem;
    }
    .hero-sub { margin-top: 0.85rem; }
    .hero-ctas { margin-top: 1.1rem; }
    .hero-widget { margin-top: 1.25rem; }
  }
</style>

<script>
  function initTryCta() {
    const card = document.getElementById("quoter-widget");
    if (!card) return;
    document.querySelectorAll("[data-try]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const lenis = (window as any).__lenis;
        if (lenis) {
          // Center the card in the viewport on Lenis's own curve
          const offset = -Math.max(0, (window.innerHeight - card.offsetHeight) / 2);
          lenis.scrollTo(card, { offset });
        } else {
          card.scrollIntoView({ behavior: "smooth", block: "center" });
        }
        const input = card.querySelector("[data-input]") as HTMLInputElement | null;
        window.setTimeout(() => input?.focus({ preventScroll: true }), 500);
      });
    });
  }
  initTryCta();
  document.addEventListener("astro:after-swap", initTryCta);
</script>
