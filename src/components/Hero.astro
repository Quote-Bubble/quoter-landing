---
import LiveWidget from "./LiveWidget.astro";
---

<!--
  One-viewport hero: the whole cluster (headline → search) is vertically
  centered in the screen so the search bar stays anchored the same way on
  short and tall laptops — not pinned by fixed top padding.
-->
<section class="hero relative flex min-h-[100svh] flex-col">
  <div
    class="hero-stage relative z-10 mx-auto flex w-full max-w-6xl flex-1 flex-col items-center justify-center px-6 text-center"
  >
    <div class="hero-cluster w-full">
      <h1 class="font-display mx-auto max-w-4xl text-[clamp(2.35rem,5.8vw,4.7rem)] leading-[1.03] text-ink">
        <span class="hero-line">
          <span class="hero-line-inner">Instant Roof Quotes,</span>
        </span>
        <span class="hero-line">
          <span class="hero-line-inner">Not Site Visits.</span>
        </span>
      </h1>

      <p class="animate-in delay-3 hero-sub mx-auto max-w-xl text-[clamp(15px,1.35vw,17px)] leading-relaxed text-ink-soft">
        Get a free ballpark price for your roof in seconds, measured from
        satellite with no ladders and no pushy sales visit. Book a trusted local
        roofer only when you're ready.
      </p>

      <div class="animate-in delay-4 hero-ctas flex flex-col items-center justify-center gap-3 sm:flex-row">
        <button
          type="button"
          data-try
          class="btn-primary inline-flex w-full items-center justify-center gap-2 rounded-full px-6 py-3 text-[15px] font-semibold sm:w-auto"
        >
          Try a live quote
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <a
          href="#how"
          class="btn-ghost inline-flex w-full items-center justify-center gap-2 rounded-full px-6 py-3 text-[15px] font-semibold sm:w-auto"
        >
          How it works
        </a>
      </div>

      <div class="hero-widget mx-auto max-w-[620px] widget-load">
        <LiveWidget />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-stage {
    /* Room for absolute nav + a little air; scales with viewport height */
    padding-top: max(5.75rem, calc(env(safe-area-inset-top, 0px) + 4.5rem));
    padding-bottom: clamp(1.25rem, 3.5vh, 2.75rem);
  }

  .hero-sub {
    margin-top: clamp(1rem, 2.2vh, 1.5rem);
  }

  .hero-ctas {
    margin-top: clamp(1.35rem, 2.8vh, 2.25rem);
  }

  /* ~one button-height gap — the key difference vs a tall fixed mt-20 */
  .hero-widget {
    margin-top: clamp(1.5rem, 3.8vh, 2.75rem);
  }

  /* Short laptops: keep the cluster tight so nothing falls off the fold */
  @media (max-height: 740px) {
    .hero-stage {
      justify-content: flex-start;
      padding-top: 5.25rem;
      padding-bottom: 1rem;
    }
    .hero-sub {
      margin-top: 0.85rem;
    }
    .hero-ctas {
      margin-top: 1.1rem;
    }
    .hero-widget {
      margin-top: 1.25rem;
    }
  }
</style>

<script>
  // "Try a live quote" focuses the widget's address field.
  function initTryCta() {
    const card = document.getElementById("quoter-widget");
    if (!card) return;
    document.querySelectorAll("[data-try]").forEach((btn) => {
      btn.addEventListener("click", () => {
        card.scrollIntoView({ behavior: "smooth", block: "center" });
        const input = card.querySelector("[data-input]") as HTMLInputElement | null;
        window.setTimeout(() => input?.focus({ preventScroll: true }), 500);
      });
    });
  }
  initTryCta();
  document.addEventListener("astro:after-swap", initTryCta);
</script>
