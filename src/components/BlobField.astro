---
// Visible "children" of the hero blob: small saturated blue orbs drifting
// at the edges of the white zones, so the blue atmosphere never fully
// leaves the page. Decorative only — sits behind all section content.
---

<div class="blob-field" aria-hidden="true">
  <div class="bf b1"></div>
  <div class="bf b2"></div>
  <div class="bf b3"></div>
  <div class="bf b4"></div>
</div>

<style>
  .blob-field {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .bf {
    position: absolute;
    width: var(--s, 420px);
    height: var(--s, 420px);
    background: radial-gradient(
      circle at 50% 50%,
      var(--c1) 0%,
      var(--c2) 45%,
      transparent 72%
    );
    filter: blur(34px);
    /* Rasterized once, then drifts on the compositor only */
    will-change: transform;
    animation: bf-drift var(--d, 11s) ease-in-out var(--dl, 0s) infinite;
  }

  /* Left edge, beside the how-it-works cards */
  .b1 {
    --s: 500px;
    --c1: rgba(47, 107, 255, 0.62);
    --c2: rgba(79, 139, 255, 0.32);
    --d: 12s;
    left: -170px;
    top: 46%;
  }
  /* Right edge, lower how-it-works */
  .b2 {
    --s: 380px;
    --c1: rgba(31, 87, 240, 0.55);
    --c2: rgba(47, 107, 255, 0.26);
    --d: 10s;
    --dl: -3s;
    right: -130px;
    top: 62%;
  }
  /* Right edge, behind the footer CTA */
  .b3 {
    --s: 460px;
    --c1: rgba(79, 139, 255, 0.6);
    --c2: rgba(47, 107, 255, 0.3);
    --d: 13s;
    --dl: -6s;
    right: -150px;
    top: 83%;
  }
  /* Small one at the page's final corner */
  .b4 {
    --s: 320px;
    --c1: rgba(47, 107, 255, 0.5);
    --c2: rgba(79, 139, 255, 0.24);
    --d: 9s;
    --dl: -2s;
    left: -110px;
    top: 91%;
  }

  @keyframes bf-drift {
    0%,
    100% {
      transform: translate3d(0, -16px, 0);
    }
    50% {
      transform: translate3d(0, 20px, 0);
    }
  }

  @media (max-width: 640px) {
    .bf {
      filter: blur(26px);
    }
    .b1 { --s: 310px; left: -130px; }
    .b2 { --s: 250px; right: -105px; }
    .b3 { --s: 290px; right: -115px; }
    .b4 { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .bf {
      animation: none;
    }
  }
</style>
