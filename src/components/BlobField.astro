---
// Children of the hero blob — each one is literally a soft-edged cutout
// sampled from the same artwork (bg-v3.webp), so hue and character match
// the hero exactly. Organic asymmetric shapes, each rotated differently,
// drifting slowly. Decorative only — behind all section content.
---

<div class="blob-field" aria-hidden="true">
  <div class="bf b1"></div>
  <div class="bf b2"></div>
  <div class="bf b3"></div>
  <div class="bf b4"></div>
</div>

<style>
  .blob-field {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .bf {
    position: absolute;
    width: var(--w, 420px);
    height: var(--h, 340px);
    background-image: url("/bg-v3.webp");
    background-repeat: no-repeat;
    background-size: var(--bs, 1500px) auto;
    background-position: var(--bp, -450px -300px);
    /* Asymmetric organic silhouette — no two alike, nothing circular */
    border-radius: var(--br, 62% 38% 54% 46% / 44% 58% 42% 56%);
    /* Heavier blur + softened colour so they sit back as quiet atmosphere */
    filter: blur(40px) saturate(0.95);
    opacity: 0;
    transform: rotate(var(--rot, 0deg));
    /* Rasterized once; the wander runs on the compositor only */
    will-change: transform, opacity;
    animation:
      bf-born 1.8s var(--ease-out-soft) calc(1.2s + var(--dl, 0s) * -0.1) forwards,
      bf-live var(--d, 16s) ease-in-out var(--dl, 0s) infinite;
  }

  /* Born out of the page as the bloom settles — quiet presence */
  @keyframes bf-born {
    to {
      opacity: 0.5;
    }
  }

  /* Alive: a slow three-phase wander — each blob drifts on a loop through
     space while squish-breathing and swaying its rotation, so the motion
     is clearly there yet never grabs the eye. Transform-only. */
  @keyframes bf-live {
    0%,
    100% {
      transform: rotate(var(--rot, 0deg)) translate3d(0, -20px, 0) scale(1.07, 0.94);
    }
    33% {
      transform: rotate(calc(var(--rot, 0deg) + 9deg)) translate3d(26px, 12px, 0)
        scale(0.94, 1.08);
    }
    66% {
      transform: rotate(calc(var(--rot, 0deg) - 7deg)) translate3d(-22px, 26px, 0)
        scale(1.04, 0.96);
    }
  }

  /* Left edge, beside the how-it-works cards — samples the cloud's left core */
  .b1 {
    --w: 500px;
    --h: 400px;
    --bp: -430px -290px;
    --rot: -10deg;
    --d: 18s;
    left: -190px;
    top: 46%;
  }
  /* Right edge, lower how-it-works — samples the dense center of the cloud */
  .b2 {
    --w: 380px;
    --h: 300px;
    --bp: -760px -420px;
    --br: 45% 55% 62% 38% / 56% 44% 58% 42%;
    --rot: 12deg;
    --d: 15s;
    --dl: -3s;
    right: -150px;
    top: 62%;
  }
  /* Right edge, behind the footer CTA — samples the deep-blue hills */
  .b3 {
    --w: 460px;
    --h: 370px;
    --bp: -520px -2420px;
    --br: 55% 45% 40% 60% / 60% 42% 58% 40%;
    --rot: -7deg;
    --d: 20s;
    --dl: -6s;
    right: -170px;
    top: 83%;
  }
  /* Small one at the page's final corner — samples the cyan cloud edge */
  .b4 {
    --w: 320px;
    --h: 250px;
    --bp: -300px -250px;
    --br: 58% 42% 48% 52% / 42% 60% 40% 58%;
    --rot: 18deg;
    --d: 14s;
    --dl: -2s;
    left: -120px;
    top: 91%;
  }


  @media (max-width: 640px) {
    .bf {
      filter: blur(30px) saturate(0.95);
    }
    .b1 { --w: 320px; --h: 260px; --bs: 1000px; --bp: -290px -195px; left: -140px; }
    .b2 { --w: 250px; --h: 200px; --bs: 1000px; --bp: -500px -280px; right: -110px; }
    .b3 { --w: 290px; --h: 235px; --bs: 1000px; --bp: -350px -1610px; right: -125px; }
    .b4 { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .bf {
      animation: none;
      /* Must still land visible without the born animation */
      opacity: 0.5;
    }
  }
</style>
