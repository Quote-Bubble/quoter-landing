---
const year = new Date().getFullYear();
---

<!-- final CTA -->
<section class="cv-auto relative mx-auto max-w-3xl px-4 pt-6 pb-16 text-center sm:px-6 sm:pt-8 sm:pb-20" data-reveal="scale">
  <h2 class="font-display text-[clamp(1.7rem,6vw,2.8rem)] leading-[1.06] text-ink">
    Find out what your roof will cost.
  </h2>
  <p class="mx-auto mt-4 max-w-md text-[15px] leading-relaxed text-ink-soft sm:text-[16px]">
    Type in your address and you will have a free estimate in seconds. You
    do not need to give any other details.
  </p>
  <button
    type="button"
    data-try
    class="btn-primary mt-7 inline-flex w-full max-w-xs items-center justify-center gap-2 rounded-full px-7 py-3.5 text-[15px] font-semibold sm:mt-8 sm:w-auto"
  >
    Get my free quote
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
      <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</section>

<!-- giant-brand footer: the wordmark stands alone over the deepening blue,
     with the legal strip closing the page beneath it -->
<footer class="footer-giant relative">
  <div class="relative z-10 mx-auto max-w-6xl px-4 pt-12 sm:px-6 sm:pt-16">
    <nav class="flex items-center justify-center gap-8 text-[14px] text-ink-soft">
      <a href="#how" class="transition-colors hover:text-ink">How it works</a>
      <a href="mailto:hello@quoter.app" class="transition-colors hover:text-ink">Contact</a>
    </nav>
  </div>

  <div data-reveal="fade">
    <div class="giant-word" aria-hidden="true">QUOTER</div>
  </div>

  <div class="footer-legal">
    <p>Prices shown are ballpark figures. A qualified local roofer confirms every quote.</p>
    <p>© {year}. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer-giant {
    overflow: hidden;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0) 0%,
      #eaf1ff 24%,
      #bcd4ff 55%,
      #7dabff 82%,
      #4f8bff 100%
    );
  }

  .giant-word {
    margin-top: clamp(1.25rem, 4vw, 3rem);
    font-family: var(--font-sans);
    font-weight: 830;
    font-size: clamp(3.4rem, 18.5vw, 21rem);
    line-height: 0.75;
    letter-spacing: -0.045em;
    text-align: center;
    white-space: nowrap;
    color: #ffffff;
    opacity: 0.85;
    user-select: none;
    pointer-events: none;
    /* Sink the baseline so the legal strip crops the word's feet, like it
       continues beneath the page */
    transform: translateY(0.12em);
  }

  /* Legal strip: paints over the wordmark's sunken feet and closes the
     page in solid brand blue */
  .footer-legal {
    position: relative;
    z-index: 5;
    background: linear-gradient(180deg, #4f8bff 0%, #2f6bff 100%);
    padding: 16px 20px calc(16px + env(safe-area-inset-bottom, 0px));
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 6px 22px;
    text-align: center;
  }
  .footer-legal p {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.85);
  }
</style>
