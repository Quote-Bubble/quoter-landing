---
const year = new Date().getFullYear();
---

<!-- Sharp closer: sends people back to the address field -->
<section
  class="footer-cta cv-auto relative mx-auto max-w-3xl px-4 pt-6 pb-14 text-center sm:px-6 sm:pt-8 sm:pb-16"
  data-reveal="scale"
>
  <p class="footer-cta-line font-display">Want free roof quotes on your website?</p>
  <button type="button" data-try class="footer-cta-link">
    Try it free above
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</section>

<footer class="footer-giant relative">
  <div class="giant-wrap" data-reveal="brand-echo">
    <div class="giant-word" aria-hidden="true">Quoter</div>
  </div>

  <div class="footer-legal">
    <a href="/terms">Terms of Service</a>
    <a href="/privacy">Privacy Policy</a>
    <span>© {year} Quoter. All rights reserved.</span>
  </div>
</footer>

<style>
  .footer-cta-line {
    margin: 0;
    font-size: clamp(1.6rem, 4.5vw, 2.35rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.1;
    color: var(--color-ink);
  }

  .footer-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.85rem;
    padding: 0.35rem 0.25rem;
    border: 0;
    background: none;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-brand-600);
    cursor: pointer;
    transition: color 0.15s ease, transform 0.2s var(--ease-out-soft, ease);
  }
  .footer-cta-link:hover {
    color: var(--color-brand-700);
  }
  .footer-cta-link:focus-visible {
    outline: 2px solid var(--color-brand-500);
    outline-offset: 4px;
    border-radius: 6px;
  }

  .footer-giant {
    overflow: hidden;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0) 0%,
      #eaf1ff 24%,
      #bcd4ff 55%,
      #7dabff 82%,
      #4f8bff 100%
    );
  }

  .giant-wrap {
    display: flex;
    justify-content: center;
    padding-inline: 0.5rem;
  }

  .giant-word {
    margin-top: clamp(1.25rem, 4vw, 3rem);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(3.6rem, 19vw, 22rem);
    line-height: 0.9;
    letter-spacing: -0.045em;
    text-align: center;
    white-space: nowrap;
    color: #ffffff;
    opacity: 0.88;
    user-select: none;
    pointer-events: none;
  }

  .footer-legal {
    position: relative;
    z-index: 5;
    background: linear-gradient(180deg, #4f8bff 0%, #2f6bff 100%);
    padding: 15px 20px calc(15px + env(safe-area-inset-bottom, 0px));
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 6px 26px;
    text-align: center;
    font-size: 12.5px;
  }
  .footer-legal a {
    color: rgba(255, 255, 255, 0.92);
    transition: color 0.15s ease;
  }
  .footer-legal a:hover {
    color: #ffffff;
    text-decoration: underline;
  }
  .footer-legal span {
    color: rgba(255, 255, 255, 0.75);
  }
</style>
