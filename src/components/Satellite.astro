---
// Satellite section — zoom in, then the original scan + outline.
//
// To set the roof outline:
// 1. npm run dev → open http://localhost:4321/trace-roof.html
// 2. Click clockwise around the outer eaves (~20–40 points)
// 3. Close shape → Copy path → paste into roofPath below
const roofPath =
  "M277 356 L277 408 L277 480 L277 508 L308 512 L335 517 L339 533 L339 544 L411 545 L474 545 L534 545 L571 547 L625 548 L677 548 L724 551 L725 534 L774 526 L789 513 L807 490 L808 450 L794 428 L784 423 L784 387 L783 341 L777 318 L778 287 L778 255 L725 245 L669 241 L616 239 L611 201 L600 200 L601 141 L546 138 L494 140 L482 140 L479 197 L469 207 L467 239 L362 239 L357 324 L341 334 L342 354 L314 357 Z";
---

<section id="tech" class="relative w-full pt-6 pb-16 sm:pt-12 sm:pb-28" data-sat>
  <!-- Full-bleed sky: reaches up into the hero blob’s fade for a continuous handoff -->
  <div class="sat-panel-bg" aria-hidden="true">
    <canvas class="sat-clouds" data-clouds></canvas>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6">
    <div class="sat-inner px-4 py-12 sm:px-10 sm:py-24 lg:px-12 lg:py-28">
      <div class="sat-layout">
        <div class="sat-copy" data-reveal="left">
          <h2 class="font-display sat-title">
            It starts from space.
          </h2>
          <p class="sat-body">
            Quoter takes Google satellite data and measures the area of
            nearly any roof in the country in seconds. It knows the angle
            of the roof too, so don't worry.
          </p>
        </div>

        <div class="sat-wrap" aria-hidden="true" data-reveal="right" data-delay="1">
          <div class="sat-card">
            <div class="sat-stage">
              <img
                class="sat-photo"
                src="/satellite-roof.webp"
                alt=""
                width="640"
                height="480"
                loading="eager"
                fetchpriority="low"
                decoding="async"
              />

              <svg class="sat-overlay" viewBox="0 0 1024 768" preserveAspectRatio="xMidYMid slice">
                <defs>
                  <filter id="sat-glow-soft" x="-50%" y="-50%" width="200%" height="200%">
                    <feGaussianBlur stdDeviation="6" result="blur" />
                    <feMerge>
                      <feMergeNode in="blur" />
                    </feMerge>
                  </filter>
                  <filter id="sat-glow-core" x="-35%" y="-35%" width="170%" height="170%">
                    <feGaussianBlur stdDeviation="2" result="blur" />
                    <feMerge>
                      <feMergeNode in="blur" />
                      <feMergeNode in="SourceGraphic" />
                    </feMerge>
                  </filter>
                </defs>

                {roofPath && (
                  <g class="sat-roof">
                    <path class="sat-roof-fill" d={roofPath} />
                    <path class="sat-roof-glow" d={roofPath} filter="url(#sat-glow-soft)" />
                    <path class="sat-roof-line" d={roofPath} filter="url(#sat-glow-core)" />
                  </g>
                )}

              </svg>
            </div>

            <div class="sat-vignette"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Compact cloudscape panel: a rounded panel of live WebGL clouds floating
     on the white page. The gradient below is the fallback shown until the
     shader's first frame (and if WebGL is unavailable). */
  /* Blended cloudscape feature — not a card. The sky layer bleeds well
     beyond the content on every side and fades out through a two-axis soft
     mask, so the clouds materialize out of the page. The top bleed reaches
     up into the hero blob's fade-out tail, so blob and clouds hand off into
     each other with no boundary. Only the background is masked; the content
     on top stays crisp. */
  /* Soft wide band — H/V fades only (no oval). Long ramps dissolve into the
     page; corners soften naturally where both axes fade. */
  .sat-panel-bg {
    position: absolute;
    /* Reach well into the hero so blob + sky overlap in the same band */
    top: -380px;
    bottom: -200px;
    left: 0;
    right: 0;
    max-width: 100%;
    overflow: hidden;
    background:
      radial-gradient(ellipse 48% 32% at 18% 34%, rgba(255, 255, 255, 0.72), transparent 68%),
      radial-gradient(ellipse 42% 28% at 68% 38%, rgba(255, 255, 255, 0.65), transparent 66%),
      radial-gradient(ellipse 36% 26% at 42% 58%, rgba(255, 255, 255, 0.45), transparent 70%),
      radial-gradient(ellipse 34% 24% at 82% 62%, rgba(255, 255, 255, 0.55), transparent 65%),
      radial-gradient(ellipse 30% 20% at 28% 70%, rgba(220, 235, 255, 0.4), transparent 68%),
      linear-gradient(180deg, #1f57f0 0%, #2f6bff 45%, #4f8bff 100%);
    /* Soft wide band — longer TOP fade so it dissolves into the blob */
    -webkit-mask-image:
      linear-gradient(
        to right,
        transparent 0%,
        rgba(0, 0, 0, 0.12) 5%,
        rgba(0, 0, 0, 0.5) 12%,
        #000 22%,
        #000 78%,
        rgba(0, 0, 0, 0.5) 88%,
        rgba(0, 0, 0, 0.12) 95%,
        transparent 100%
      ),
      linear-gradient(
        to bottom,
        transparent 0%,
        rgba(0, 0, 0, 0.08) 10%,
        rgba(0, 0, 0, 0.35) 20%,
        rgba(0, 0, 0, 0.75) 32%,
        #000 42%,
        #000 72%,
        rgba(0, 0, 0, 0.55) 84%,
        rgba(0, 0, 0, 0.15) 92%,
        transparent 100%
      );
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(
        to right,
        transparent 0%,
        rgba(0, 0, 0, 0.12) 5%,
        rgba(0, 0, 0, 0.5) 12%,
        #000 22%,
        #000 78%,
        rgba(0, 0, 0, 0.5) 88%,
        rgba(0, 0, 0, 0.12) 95%,
        transparent 100%
      ),
      linear-gradient(
        to bottom,
        transparent 0%,
        rgba(0, 0, 0, 0.08) 10%,
        rgba(0, 0, 0, 0.35) 20%,
        rgba(0, 0, 0, 0.75) 32%,
        #000 42%,
        #000 72%,
        rgba(0, 0, 0, 0.55) 84%,
        rgba(0, 0, 0, 0.15) 92%,
        transparent 100%
      );
    mask-composite: intersect;
    pointer-events: none;
  }
  /* Mobile: same soft, blended sky as desktop — long fade ramps on every
     side and enough top bleed to hand off from the hero blob's fade tail. */
  @media (max-width: 640px) {
    .sat-panel-bg {
      top: -160px;
      bottom: -80px;
      -webkit-mask-image:
        linear-gradient(
          to right,
          transparent 0%,
          rgba(0, 0, 0, 0.15) 4%,
          rgba(0, 0, 0, 0.55) 9%,
          #000 16%,
          #000 84%,
          rgba(0, 0, 0, 0.55) 91%,
          rgba(0, 0, 0, 0.15) 96%,
          transparent 100%
        ),
        linear-gradient(
          to bottom,
          transparent 0%,
          rgba(0, 0, 0, 0.1) 6%,
          rgba(0, 0, 0, 0.4) 13%,
          rgba(0, 0, 0, 0.8) 20%,
          #000 27%,
          #000 78%,
          rgba(0, 0, 0, 0.5) 89%,
          rgba(0, 0, 0, 0.12) 96%,
          transparent 100%
        );
      -webkit-mask-composite: source-in;
      mask-image:
        linear-gradient(
          to right,
          transparent 0%,
          rgba(0, 0, 0, 0.15) 4%,
          rgba(0, 0, 0, 0.55) 9%,
          #000 16%,
          #000 84%,
          rgba(0, 0, 0, 0.55) 91%,
          rgba(0, 0, 0, 0.15) 96%,
          transparent 100%
        ),
        linear-gradient(
          to bottom,
          transparent 0%,
          rgba(0, 0, 0, 0.1) 6%,
          rgba(0, 0, 0, 0.4) 13%,
          rgba(0, 0, 0, 0.8) 20%,
          #000 27%,
          #000 78%,
          rgba(0, 0, 0, 0.5) 89%,
          rgba(0, 0, 0, 0.12) 96%,
          transparent 100%
        );
      mask-composite: intersect;
    }
  }
  .sat-clouds {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
  }
  /* Deep blue scrim under the copy zone: clouds can drift behind the text
     but can never get bright enough there to wash the white type out */
  .sat-panel-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 48% 62% at 24% 48%,
      rgba(16, 48, 150, 0.62) 0%,
      rgba(24, 70, 200, 0.35) 45%,
      rgba(31, 87, 240, 0.1) 70%,
      transparent 100%
    );
    pointer-events: none;
  }
  @media (max-width: 640px) {
    .sat-panel-bg::after {
      background: radial-gradient(
        ellipse 95% 58% at 50% 28%,
        rgba(16, 48, 150, 0.62) 0%,
        rgba(24, 70, 200, 0.35) 45%,
        rgba(31, 87, 240, 0.1) 70%,
        transparent 80%
      );
    }
  }

  .sat-layout {
    display: grid;
    align-items: center;
    gap: 2rem;
  }
  @media (min-width: 1024px) {
    .sat-layout {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
      gap: 3rem;
    }
  }

  .sat-copy {
    position: relative;
    text-align: center;
    max-width: 28rem;
    margin-inline: auto;
  }
  .sat-title {
    margin: 0.9rem 0 0;
    font-size: clamp(2.1rem, 5.2vw, 3.35rem);
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: #fff;
  }
  .sat-body {
    margin: 1.1rem 0 0;
    max-width: 28rem;
    font-size: clamp(1.05rem, 1.9vw, 1.25rem);
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.92);
  }
  @media (max-width: 640px) {
    .sat-title {
      font-size: clamp(1.85rem, 8vw, 2.35rem);
    }
    .sat-body {
      font-size: 1.05rem;
      margin-inline: auto;
    }
  }
  @media (min-width: 1024px) {
    .sat-copy {
      text-align: left;
      margin-inline: 0;
      max-width: 22rem;
    }
    .sat-body {
      max-width: 22rem;
    }
  }
  @media (min-width: 1200px) {
    .sat-copy,
    .sat-body {
      max-width: 26rem;
    }
  }
  .sat-title,
  .sat-body {
    text-shadow:
      0 1px 2px rgba(5, 20, 70, 0.55),
      0 2px 14px rgba(5, 20, 70, 0.7),
      0 8px 36px rgba(5, 20, 70, 0.85);
  }
  .sat-wrap {
    width: 100%;
    max-width: 560px;
    margin-inline: auto;
  }
  @media (min-width: 1024px) {
    .sat-wrap {
      max-width: none;
      width: 100%;
      margin-inline: 0 0 0 auto;
    }
  }
  @media (min-width: 1200px) {
    .sat-layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
      gap: 3.25rem;
    }
  }

  .sat-card {
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.65);
    box-shadow:
      0 0 0 1px rgba(21, 55, 140, 0.18),
      0 24px 48px -18px rgba(15, 40, 100, 0.5);
    aspect-ratio: 4 / 3;
    background: #1a1e16;
  }

  .sat-stage {
    position: absolute;
    inset: 0;
    transform: scale(1);
    transform-origin: center center;
    /* Pre-promote: the zoom layer is composited at load, not at scroll-in */
    will-change: transform;
  }

  .sat-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  .sat-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 58% 52% at 50% 50%,
      transparent 35%,
      rgba(8, 12, 24, 0.4) 100%
    );
    pointer-events: none;
    z-index: 2;
  }

  .sat-overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .sat-roof-fill {
    fill: rgba(47, 107, 255, 0.28);
    opacity: 0;
  }
  .sat-roof-glow,
  .sat-roof-line {
    fill: none;
    stroke-linejoin: round;
    stroke-linecap: round;
    stroke-dasharray: var(--sat-len, 2400);
    stroke-dashoffset: var(--sat-len, 2400);
  }
  .sat-roof-glow {
    stroke: rgba(120, 175, 255, 1);
    stroke-width: 16;
    opacity: 0.9;
  }
  .sat-roof-line {
    stroke: #e8f1ff;
    stroke-width: 3.25;
  }

  /* Perpetual loop (~8s): zoom → draw outline → fill → hold → reset */
  .sat-card.playing .sat-stage {
    animation: sat-zoom-loop 8s cubic-bezier(0.4, 0.05, 0.2, 1) infinite;
  }
  .sat-card.playing .sat-roof-line {
    animation: sat-draw-loop 8s cubic-bezier(0.35, 0.05, 0.2, 1) infinite;
  }
  .sat-card.playing .sat-roof-glow {
    animation:
      sat-draw-loop 8s cubic-bezier(0.35, 0.05, 0.2, 1) infinite,
      sat-glow-loop 8s ease-in-out infinite;
  }
  .sat-card.playing .sat-roof-fill {
    animation: sat-fill-loop 8s ease infinite;
  }

  @keyframes sat-zoom-loop {
    0%,
    5% {
      transform: scale(1);
    }
    18%,
    72% {
      transform: scale(1.28);
    }
    88%,
    100% {
      transform: scale(1);
    }
  }

  /* Draw + scan: 20% → 52% of the cycle (~2.5s) */
  @keyframes sat-draw-loop {
    0%,
    20% {
      stroke-dashoffset: var(--sat-len, 2400);
    }
    52%,
    72% {
      stroke-dashoffset: 0;
    }
    88%,
    100% {
      stroke-dashoffset: var(--sat-len, 2400);
    }
  }

  @keyframes sat-fill-loop {
    0%,
    48% {
      opacity: 0;
    }
    58%,
    72% {
      opacity: 1;
    }
    84%,
    100% {
      opacity: 0;
    }
  }

  @keyframes sat-glow-loop {
    0%,
    20% {
      opacity: 0.65;
    }
    36%,
    52% {
      opacity: 1;
    }
    64%,
    72% {
      opacity: 0.9;
    }
    88%,
    100% {
      opacity: 0.65;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sat-stage {
      transform: scale(1.28);
    }
    .sat-card.playing .sat-stage,
    .sat-card.playing .sat-roof-fill,
    .sat-card.playing .sat-roof-glow,
    .sat-card.playing .sat-roof-line {
      animation: none;
    }
    .sat-card.playing .sat-roof-fill,
    .sat-card.playing .sat-roof-glow {
      opacity: 1;
    }
    .sat-card.playing .sat-roof-line,
    .sat-card.playing .sat-roof-glow {
      stroke-dashoffset: 0;
    }
  }
</style>

<script>
  function initSat() {
    const root = document.querySelector("[data-sat]");
    if (!root) return;
    const card = root.querySelector(".sat-card");
    if (!card || card.classList.contains("playing")) return;
    const paths = card.querySelectorAll(".sat-roof-line, .sat-roof-glow");
    paths.forEach((el) => {
      const path = el as SVGPathElement;
      const len = Math.ceil(path.getTotalLength()) + 2;
      path.style.setProperty("--sat-len", String(len));
    });
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            card.classList.add("playing");
            io.disconnect();
          }
        });
      },
      { threshold: 0.45 }
    );
    io.observe(card);
  }
  initSat();
  document.addEventListener("astro:after-swap", initSat);
</script>

<script>
  // Cloudscape — sharp WebGL at normal resolution; pauses offscreen.
  // Colors match the hero blob (#1f57f0 / #2f6bff / #4f8bff family).
  const CLOUD_VERT = `
attribute vec2 position;
void main() { gl_Position = vec4(position, 0.0, 1.0); }
`;

  const CLOUD_FRAG = `
precision highp float;
uniform vec2 u_resolution;
uniform float u_time;
uniform vec3 u_colorBottom;
uniform vec3 u_colorMid;
uniform vec3 u_colorTop;

float hash(vec2 p) {
  return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
}
float noise(vec2 p) {
  vec2 i = floor(p);
  vec2 f = fract(p);
  f = f * f * f * (f * (f * 6.0 - 15.0) + 10.0);
  float a = hash(i);
  float b = hash(i + vec2(1.0, 0.0));
  float c = hash(i + vec2(0.0, 1.0));
  float d = hash(i + vec2(1.0, 1.0));
  return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
}
float fbm(vec2 p) {
  float v = 0.0;
  float a = 0.5;
  mat2 r = mat2(0.8, 0.6, -0.6, 0.8);
  for (int i = 0; i < 5; i++) {
    v += a * noise(p);
    p = r * p * 2.01 + vec2(17.1, 9.3);
    a *= 0.5;
  }
  return v;
}
void main() {
  vec2 uv = gl_FragCoord.xy / u_resolution;
  vec2 p = (uv - 0.5) * vec2(u_resolution.x / max(u_resolution.y, 1.0), 1.0);
  p = mat2(0.96, 0.28, -0.28, 0.96) * p;
  vec2 wind = vec2(u_time * 0.085, u_time * 0.024);
  float large = fbm(p * 0.75 - wind * 0.45);
  float midN = fbm(p * 1.5 - wind + 3.7);
  float fine = fbm(p * 2.6 - wind * 1.2 + 8.0);
  float n = large * 0.5 + midN * 0.35 + fine * 0.15;
  /* Slightly brighter toward the top so it matches the washed blob edge */
  vec3 sky = mix(u_colorMid, u_colorBottom, uv.y * 0.55);
  float cover = smoothstep(0.28, 0.5, n);
  float peaks = smoothstep(0.42, 0.65, n);
  float clouds = clamp(cover * 0.9 + peaks * 0.7, 0.0, 1.0);
  /* Soften cloud intensity near the top handoff into the blob */
  clouds *= mix(0.55, 1.0, smoothstep(0.0, 0.45, uv.y));
  gl_FragColor = vec4(mix(sky, u_colorTop, clouds), 1.0);
}
`;

  const CLOUD_COLORS: [number, number, number][] = [
    [31 / 255, 87 / 255, 240 / 255],   // #1f57f0 — blob core
    [79 / 255, 139 / 255, 255 / 255],  // #4f8bff — blob mid
    [1.0, 1.0, 1.0],                  // bright cloud tops
  ];
  const CLOUD_VER = "blob-4";
  const FRAME_MS = 1000 / 24;

  function preferCssOnly(): boolean {
    const nav = navigator as Navigator & { deviceMemory?: number; connection?: { saveData?: boolean } };
    if (nav.connection?.saveData) return true;
    if (typeof nav.deviceMemory === "number" && nav.deviceMemory <= 2) return true;
    return false;
  }

  function initClouds() {
    document.querySelectorAll<HTMLCanvasElement>("canvas[data-clouds]").forEach((canvas) => {
      if (canvas.dataset.cloudVer === CLOUD_VER) return;
      const host = canvas.parentElement;
      if (!host) return;

      if (preferCssOnly()) {
        canvas.remove();
        return;
      }

      const old = canvas.getContext("webgl");
      if (old) old.getExtension("WEBGL_lose_context")?.loseContext();
      const next = canvas.cloneNode(false) as HTMLCanvasElement;
      canvas.replaceWith(next);
      canvas = next;

      const gl = canvas.getContext("webgl", {
        antialias: false,
        alpha: false,
        depth: false,
        stencil: false,
        powerPreference: "low-power",
        preserveDrawingBuffer: false,
      });
      if (!gl) {
        canvas.remove();
        return;
      }
      canvas.dataset.cloudVer = CLOUD_VER;

      const compile = (type: number, src: string) => {
        const s = gl.createShader(type);
        if (!s) return null;
        gl.shaderSource(s, src);
        gl.compileShader(s);
        if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
          gl.deleteShader(s);
          return null;
        }
        return s;
      };

      const vert = compile(gl.VERTEX_SHADER, CLOUD_VERT);
      const frag = compile(gl.FRAGMENT_SHADER, CLOUD_FRAG);
      if (!vert || !frag) {
        canvas.remove();
        return;
      }

      const program = gl.createProgram();
      if (!program) {
        canvas.remove();
        return;
      }
      gl.attachShader(program, vert);
      gl.attachShader(program, frag);
      gl.linkProgram(program);
      if (!gl.getProgramParameter(program, gl.LINK_STATUS)) {
        canvas.remove();
        return;
      }
      gl.useProgram(program);

      const buf = gl.createBuffer();
      gl.bindBuffer(gl.ARRAY_BUFFER, buf);
      gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]), gl.STATIC_DRAW);
      const pos = gl.getAttribLocation(program, "position");
      gl.enableVertexAttribArray(pos);
      gl.vertexAttribPointer(pos, 2, gl.FLOAT, false, 0, 0);

      const uRes = gl.getUniformLocation(program, "u_resolution");
      const uTime = gl.getUniformLocation(program, "u_time");
      gl.uniform3f(gl.getUniformLocation(program, "u_colorBottom"), ...CLOUD_COLORS[0]);
      gl.uniform3f(gl.getUniformLocation(program, "u_colorMid"), ...CLOUD_COLORS[1]);
      gl.uniform3f(gl.getUniformLocation(program, "u_colorTop"), ...CLOUD_COLORS[2]);

      let raf = 0;
      let lastFrame = 0;
      let running = false;
      const t0 = performance.now();

      const resize = () => {
        // Clouds are soft-focus: render at 1x and let the compositor upscale.
        // Indistinguishable for fbm noise, ~4x fewer shaded pixels on retina.
        const dpr = Math.min(window.devicePixelRatio || 1, 1);
        const rect = host.getBoundingClientRect();
        const w = Math.max(1, Math.floor(rect.width * dpr));
        const h = Math.max(1, Math.floor(rect.height * dpr));
        if (canvas.width === w && canvas.height === h) return;
        canvas.width = w;
        canvas.height = h;
        gl.viewport(0, 0, w, h);
        gl.uniform2f(uRes, w, h);
      };

      const draw = (now: number) => {
        gl.uniform1f(uTime, (now - t0) / 1000);
        gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
      };

      const loop = (now: number) => {
        if (!running) return;
        if (now - lastFrame >= FRAME_MS) {
          lastFrame = now;
          draw(now);
        }
        raf = requestAnimationFrame(loop);
      };

      const start = () => {
        if (running) return;
        running = true;
        resize();
        lastFrame = 0;
        raf = requestAnimationFrame(loop);
      };
      const stop = () => {
        running = false;
        if (raf) cancelAnimationFrame(raf);
        raf = 0;
      };

      resize();
      draw(t0 + 12);

      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reducedMotion) {
        let resizeTimer = 0;
        new ResizeObserver(() => {
          clearTimeout(resizeTimer);
          resizeTimer = window.setTimeout(() => {
            resize();
            draw(t0 + 12);
          }, 150);
        }).observe(host);
        return;
      }

      // Run from page load — but let the hero bloom own the GPU for its
      // first beat, then warm the clouds (still long before the user can
      // scroll down to them). Only pause when the tab itself is hidden.
      window.setTimeout(() => {
        if (!document.hidden) start();
      }, 1500);

      document.addEventListener(
        "visibilitychange",
        () => {
          if (document.hidden) stop();
          else start();
        },
        { passive: true }
      );

      let resizeTimer = 0;
      new ResizeObserver(() => {
        clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(() => {
          resize();
          if (running) draw(performance.now());
          else draw(t0 + 12);
        }, 150);
      }).observe(host);
    });
  }
  initClouds();
  document.addEventListener("astro:after-swap", initClouds);
</script>
