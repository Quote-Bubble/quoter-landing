---
import "../styles/global.css";
import SpeedInsights from "@vercel/speed-insights/astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Quoter: See your roof price in seconds",
  description = "Enter your address and get a free roof cost estimate from satellite imagery in seconds. No ladders, no sales visit, no obligation. A local roofer can confirm the exact price if you want to go ahead.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#ffffff" />
    <!-- The blob is the page visual anchor: fetch it before the CSS asks -->
    <link rel="preload" as="image" href="/bg-v3.webp" fetchpriority="high" />
    <!--
      Kill scroll restoration before first paint. Otherwise refresh-on-hero
      restores a few px (or animates there) while fonts/morph shift layout.
    -->
    <script is:inline>
      try {
        if ("scrollRestoration" in history) history.scrollRestoration = "manual";
      } catch (_) {}
      if (!location.hash) {
        window.scrollTo(0, 0);
        document.documentElement.scrollTop = 0;
        document.body.scrollTop = 0;
      }
    </script>
  </head>
  <body>
    <div class="site-bg" aria-hidden="true"></div>
    <div class="site-dots" aria-hidden="true"></div>
    <slot />

    {/*
      Real Quoter widget embed goes here when it's ready, e.g.:
      <script src="https://cdn.quoter.app/embed.js" data-quoter="YOUR_SITE_KEY" defer></script>
      It replaces the placeholder demo in DemoSection.astro (#quoter-widget).
    */}

    <SpeedInsights />
  </body>
</html>

<script>
  // Lenis smooth scrolling — a soft ease-out curve on wheel scrolling.
  // Desktop-feel only: touch keeps native momentum (hijacking touch feels
  // wrong on phones). Skipped entirely for reduced-motion users.
  import Lenis from "lenis";

  declare global {
    interface Window {
      __lenis?: Lenis;
    }
  }

  function pinTop() {
    window.scrollTo(0, 0);
    document.documentElement.scrollTop = 0;
    document.body.scrollTop = 0;
    window.__lenis?.scrollTo(0, { immediate: true, force: true });
  }

  function initLenis() {
    if (window.__lenis) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const lenis = new Lenis({
      duration: 1.1,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    });
    window.__lenis = lenis;

    function raf(time: number) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);

    // Anchor links ride the same curve
    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
      a.addEventListener("click", (e) => {
        const target = document.querySelector(a.hash);
        if (!target) return;
        e.preventDefault();
        lenis.scrollTo(target as HTMLElement, { offset: -24 });
      });
    });

    // Fresh loads should start at top; Lenis can inherit a restored offset
    if (!location.hash) pinTop();
  }

  // Hold the top through hero entrance layout shifts unless the user scrolls.
  function holdHeroTop() {
    if (location.hash) return;

    let userScrolled = false;
    const mark = () => {
      userScrolled = true;
    };
    window.addEventListener("wheel", mark, { passive: true, once: true });
    window.addEventListener("touchmove", mark, { passive: true, once: true });
    window.addEventListener("keydown", (e) => {
      if (
        e.key === "ArrowDown" ||
        e.key === "ArrowUp" ||
        e.key === "PageDown" ||
        e.key === "PageUp" ||
        e.key === " " ||
        e.key === "Home" ||
        e.key === "End"
      ) {
        mark();
      }
    }, { passive: true, once: true });

    pinTop();

    const started = performance.now();
    const tick = () => {
      if (!userScrolled && !location.hash && window.scrollY > 0) pinTop();
      if (performance.now() - started < 3200) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);

    window.addEventListener(
      "pageshow",
      (e) => {
        // bfcache restore can bring back a mid-scroll Lenis state
        if (e.persisted && !location.hash) pinTop();
      },
      { passive: true }
    );
  }

  initLenis();
  holdHeroTop();
  document.addEventListener("astro:after-swap", () => {
    initLenis();
    holdHeroTop();
  });
</script>

<script>
  // Scroll-triggered reveals — transform/opacity only, one observer for the page.
  function initReveals() {
    const nodes = document.querySelectorAll<HTMLElement>("[data-reveal], [data-stagger]");
    if (!nodes.length) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) {
      nodes.forEach((el) => el.classList.add("is-in"));
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-in");
          io.unobserve(entry.target);
        });
      },
      { threshold: 0.18, rootMargin: "0px 0px -8% 0px" }
    );

    nodes.forEach((el) => {
      // Already visible on first paint (e.g. tall screens) — reveal immediately
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight * 0.9 && rect.bottom > 0) {
        // Stagger a frame so CSS transitions still fire
        requestAnimationFrame(() => el.classList.add("is-in"));
      } else {
        io.observe(el);
      }
    });
  }

  initReveals();
  document.addEventListener("astro:after-swap", initReveals);
</script>
