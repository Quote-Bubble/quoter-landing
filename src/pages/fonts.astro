---
// Internal font-comparison gallery. Not linked from anywhere.
// Round 3 — Instrument Sans flagged; more in that soft-modern lane.
import Layout from "../layouts/Layout.astro";
import "@fontsource-variable/instrument-sans/wght.css";
import "@fontsource-variable/outfit/wght.css";
import "@fontsource-variable/onest/wght.css";
import "@fontsource-variable/figtree/wght.css";
import "@fontsource-variable/plus-jakarta-sans/wght.css";
import "@fontsource-variable/epilogue/wght.css";
import "@fontsource-variable/syne/wght.css";
import "@fontsource-variable/urbanist/wght.css";
import "@fontsource/dm-sans/latin-500.css";
import "@fontsource-variable/bricolage-grotesque/wght.css";

const candidates = [
  {
    name: "Instrument Sans",
    family: "'Instrument Sans Variable', sans-serif",
    weight: 520,
    spacing: "-0.025em",
    note: "Your pick so far. Soft geometric with a handmade edge.",
    flagged: true,
  },
  {
    name: "Figtree",
    family: "'Figtree Variable', sans-serif",
    weight: 550,
    spacing: "-0.02em",
    note: "Closest neighbor to Instrument Sans — friendly, rounded, modern without going cute.",
  },
  {
    name: "Outfit",
    family: "'Outfit Variable', sans-serif",
    weight: 500,
    spacing: "-0.025em",
    note: "Slightly cleaner/rounder. Soft product feel with a bit more warmth than Inter.",
  },
  {
    name: "Onest",
    family: "'Onest Variable', sans-serif",
    weight: 550,
    spacing: "-0.025em",
    note: "Geometric with subtle oddness in the curves. Modern, a little more character.",
  },
  {
    name: "Plus Jakarta Sans",
    family: "'Plus Jakarta Sans Variable', sans-serif",
    weight: 560,
    spacing: "-0.02em",
    note: "Polished and contemporary. A touch more “designed brand” than Instrument.",
  },
  {
    name: "DM Sans",
    family: "'DM Sans', sans-serif",
    weight: 500,
    spacing: "-0.02em",
    note: "Low-contrast geometric. Quiet personality — less quirky, still not sterile.",
  },
  {
    name: "Urbanist",
    family: "'Urbanist Variable', sans-serif",
    weight: 520,
    spacing: "-0.03em",
    note: "Tall, airy, a bit fashion-forward. More attitude in the proportions.",
  },
  {
    name: "Epilogue",
    family: "'Epilogue Variable', sans-serif",
    weight: 540,
    spacing: "-0.02em",
    note: "Soft terminals and open shapes. Friendly modern — closer to Instrument’s warmth.",
  },
  {
    name: "Syne",
    family: "'Syne Variable', sans-serif",
    weight: 600,
    spacing: "-0.02em",
    note: "The wilder option in this lane. Distinctive, artsy, still readable as a headline.",
  },
  {
    name: "Bricolage Grotesque",
    family: "'Bricolage Grotesque Variable', sans-serif",
    weight: 560,
    spacing: "-0.03em",
    note: "Kept from round 2 — more oddball than Instrument if you want to push further.",
  },
];
---

<Layout title="Font lab | Quoter" description="Internal font comparison.">
  <main class="relative z-10 mx-auto max-w-4xl px-6 py-20">
    <h1 class="text-[14px] font-semibold uppercase tracking-[0.14em] text-brand-600">
      Font lab · round 3
    </h1>
    <p class="mt-2 max-w-xl text-[15px] text-ink-soft">
      Instrument Sans is flagged. Everything else is in a similar soft-modern lane — pick neighbors or something with more bite.
    </p>

    <div class="mt-10 flex flex-col gap-6">
      {candidates.map((f) => (
        <section class:list={["font-card rounded-3xl p-8 sm:p-10", f.flagged && "font-card--flagged"]}>
          <div class="flex flex-wrap items-center gap-2">
            <p class="text-[12.5px] font-semibold uppercase tracking-[0.1em] text-brand-600">{f.name}</p>
            {f.flagged && (
              <span class="rounded-full bg-brand-600 px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-[0.08em] text-white">
                Flagged
              </span>
            )}
          </div>
          <p class="mt-0.5 text-[13px] text-muted">{f.note}</p>
          <h2
            class="mt-5 text-ink"
            style={`font-family:${f.family};font-weight:${f.weight};letter-spacing:${f.spacing};font-size:clamp(2rem,5.4vw,3.6rem);line-height:1.05;`}
          >
            Instant Roof Quotes,<br />Not Site Visits.
          </h2>
          <p class="mt-4 max-w-lg text-[15.5px] leading-relaxed text-ink-soft">
            Type in your address and Quoter measures your roof from satellite
            photos, giving you a
            <strong class="font-semibold text-brand-600">free estimate</strong>
            in seconds.
          </p>
        </section>
      ))}
    </div>
  </main>
</Layout>

<style>
  .font-card {
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(255, 255, 255, 0.75);
    box-shadow: var(--shadow-soft);
  }
  .font-card--flagged {
    border-color: rgba(47, 107, 255, 0.45);
    box-shadow:
      0 0 0 1px rgba(47, 107, 255, 0.12),
      var(--shadow-soft);
  }
</style>
